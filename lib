    selectedLabel.Position = UDim2.new(0, 5, 0, 0)
    selectedLabel.TextXAlignment = Enum.TextXAlignment.Center
    selectedLabel.Parent = selectedPill

    local optScroll = Instance.new("ScrollingFrame")
    optScroll.Name = "Options"
    optScroll.BackgroundTransparency = 1
    optScroll.Size = UDim2.new(1, 0, 0, 0)
    optScroll.Position = UDim2.new(0, 0, 0, 42)
    optScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    optScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    optScroll.ScrollBarThickness = 4
    optScroll.ScrollBarImageColor3 = Theme.Accent
    optScroll.ScrollBarImageTransparency = 0.2
    optScroll.TopImage = ""
    optScroll.MidImage = ""
    optScroll.BottomImage = ""
    optScroll.ScrollingDirection = Enum.ScrollingDirection.Y
    optScroll.Visible = false
    optScroll.Parent = holder

    local optLayout = Instance.new("UIListLayout")
    optLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optLayout.Padding = UDim.new(0, 2)
    optLayout.Parent = optScroll

    local optPad = Instance.new("UIPadding")
    optPad.PaddingLeft = UDim.new(0, 6)
    optPad.PaddingRight = UDim.new(0, 6)
    optPad.PaddingTop = UDim.new(0, 4)
    optPad.PaddingBottom = UDim.new(0, 6)
    optPad.Parent = optScroll

    local function closeDropdown()
        open = false
        tween(holder, {Size = UDim2.new(1, 0, 0, 32)}, 0.2)
        tween(pillStroke, {Color = Theme.Border}, 0.15)
        task.delay(0.2, function()
            if not open then optScroll.Visible = false end
        end)
    end

    local function selectPlayer(name)
        selected = name
        selectedLabel.Text = name or "None"
        for _, data in ipairs(optButtons) do
            if data.name == name then
                tween(data.btn, {BackgroundColor3 = Theme.Accent, BackgroundTransparency = 0.3}, 0.15)
            else
                tween(data.btn, {BackgroundColor3 = Theme.GlassHover, BackgroundTransparency = 0.5}, 0.15)
            end
        end
        if config.Callback then config.Callback(name) end
        closeDropdown()
    end

    local function refreshPlayers()
        for _, data in ipairs(optButtons) do
            data.btn:Destroy()
        end
        optButtons = {}

        local players = Players:GetPlayers()
        local localPlayer = Players.LocalPlayer
        for i, plr in ipairs(players) do
            if plr ~= localPlayer or config.IncludeSelf then
                local optBtn = Instance.new("TextButton")
                optBtn.Name = "Opt_" .. plr.Name
                optBtn.Text = "  " .. plr.DisplayName .. " (@" .. plr.Name .. ")"
                optBtn.Font = Theme.Font
                optBtn.TextSize = 11
                optBtn.TextXAlignment = Enum.TextXAlignment.Left
                optBtn.TextColor3 = Theme.Text
                optBtn.BackgroundColor3 = (selected == plr.Name) and Theme.Accent or Theme.GlassHover
                optBtn.BackgroundTransparency = (selected == plr.Name) and 0.3 or 0.5
                optBtn.Size = UDim2.new(1, 0, 0, 24)
                optBtn.AutoButtonColor = false
                optBtn.LayoutOrder = i
                optBtn.Parent = optScroll
                applySmallCorner(optBtn)

                table.insert(optButtons, {btn = optBtn, name = plr.Name})

                optBtn.MouseEnter:Connect(function()
                    if plr.Name ~= selected then
                        tween(optBtn, {BackgroundTransparency = 0.2}, 0.15)
                    end
                end)
                optBtn.MouseLeave:Connect(function()
                    if plr.Name ~= selected then
                        tween(optBtn, {BackgroundTransparency = 0.5}, 0.15)
                    end
                end)
                optBtn.MouseButton1Click:Connect(function()
                    selectPlayer(plr.Name)
                end)
            end
        end

        -- If selected player left, reset
        if selected then
            local found = false
            for _, data in ipairs(optButtons) do
                if data.name == selected then found = true; break end
            end
            if not found then
                selected = nil
                selectedLabel.Text = "None"
                if config.Callback then config.Callback(nil) end
            end
        end
    end

    -- Auto-refresh on player join/leave
    Players.PlayerAdded:Connect(function()
        if open then
            refreshPlayers()
            local count = #optButtons
            local listH = math.min(count * 26 + 10, 130)
            optScroll.Size = UDim2.new(1, 0, 0, listH)
            tween(holder, {Size = UDim2.new(1, 0, 0, 42 + listH)}, 0.2)
        end
    end)
    Players.PlayerRemoving:Connect(function()
        task.defer(function()
            if open then
                refreshPlayers()
                local count = #optButtons
                local listH = math.min(count * 26 + 10, 130)
                optScroll.Size = UDim2.new(1, 0, 0, listH)
                tween(holder, {Size = UDim2.new(1, 0, 0, 42 + listH)}, 0.2)
            end
        end)
    end)

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Text = ""
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Size = UDim2.new(1, 0, 0, 32)
    toggleBtn.ZIndex = 5
    toggleBtn.Parent = holder
    toggleBtn.MouseButton1Click:Connect(function()
        if open then
            closeDropdown()
        else
            open = true
            refreshPlayers()
            optScroll.Visible = true
            tween(pillStroke, {Color = Theme.Accent}, 0.15)
            local count = #optButtons
            local listH = math.min(count * 26 + 10, 130)
            optScroll.Size = UDim2.new(1, 0, 0, listH)
            tween(holder, {Size = UDim2.new(1, 0, 0, 42 + listH)}, 0.2)
        end
    end)

    return {
        Get = function() return selected end,
        Refresh = refreshPlayers,
    }
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: MULTI-SELECT DROPDOWN
-- ═══════════════════════════════════════════════════
function Category:AddMultiDropdown(config)
    config = config or {}
    local col, ci = self:_getColumn(config.Column)
    local order = self:_incOrder(ci)
    local options = config.Options or {}
    local selected = {}
    if config.Default then
        for _, v in ipairs(config.Default) do selected[v] = true end
    end
    local open = false

    local holder = Instance.new("Frame")
    holder.Name = config.Name or "MultiDropdown"
    holder.BackgroundColor3 = Theme.Glass
    holder.BackgroundTransparency = Theme.Transparency
    holder.Size = UDim2.new(1, 0, 0, 32)
    holder.LayoutOrder = order
    holder.ClipsDescendants = true
    holder.Parent = col
    applyGlass(holder)

    local accentBar = Instance.new("Frame")
    accentBar.Name = "AccentBar"
    accentBar.BackgroundColor3 = Theme.Accent
    accentBar.Size = UDim2.new(0, 3, 0, 20)
    accentBar.Position = UDim2.new(0, 4, 0, 6)
    accentBar.BorderSizePixel = 0
    accentBar.Parent = holder
    Instance.new("UICorner", accentBar).CornerRadius = UDim.new(1, 0)

    local label = Instance.new("TextLabel")
    label.Text = config.Text or "Multi Select"
    label.Font = Theme.Font
    label.TextSize = 12
    label.TextColor3 = Theme.SubText
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.5, -5, 0, 32)
    label.Position = UDim2.new(0, 18, 0, 0)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder

    local function getSelectedText()
        local list = {}
        for _, opt in ipairs(options) do
            if selected[opt] then table.insert(list, opt) end
        end
        if #list == 0 then return "None" end
        if #list <= 2 then return table.concat(list, ", ") end
        return list[1] .. " +" .. (#list - 1)
    end

    local selectedPill = Instance.new("Frame")
    selectedPill.Name = "SelectedPill"
    selectedPill.BackgroundColor3 = Theme.TabInactive
    selectedPill.BackgroundTransparency = 0.3
    selectedPill.Size = UDim2.new(0.5, -14, 0, 22)
    selectedPill.Position = UDim2.new(0.5, 2, 0, 5)
    selectedPill.Parent = holder
    Instance.new("UICorner", selectedPill).CornerRadius = UDim.new(0, 5)
    local pillStroke = Instance.new("UIStroke")
    pillStroke.Color = Theme.Border
    pillStroke.Transparency = Theme.BorderTransp
    pillStroke.Thickness = 1
    pillStroke.Parent = selectedPill

    local selectedLabel = Instance.new("TextLabel")
    selectedLabel.Name = "Selected"
    selectedLabel.Text = getSelectedText()
    selectedLabel.Font = Theme.Font
    selectedLabel.TextSize = 11
    selectedLabel.TextColor3 = Theme.Text
    selectedLabel.BackgroundTransparency = 1
    selectedLabel.Size = UDim2.new(1, -10, 1, 0)
    selectedLabel.Position = UDim2.new(0, 5, 0, 0)
    selectedLabel.TextXAlignment = Enum.TextXAlignment.Center
    selectedLabel.TextTruncate = Enum.TextTruncate.AtEnd
    selectedLabel.Parent = selectedPill

    local optContainer = Instance.new("Frame")
    optContainer.Name = "Options"
    optContainer.BackgroundTransparency = 1
    optContainer.Size = UDim2.new(1, 0, 0, 0)
    optContainer.Position = UDim2.new(0, 0, 0, 42)
    optContainer.Visible = false
    optContainer.Parent = holder

    local optLayout = Instance.new("UIListLayout")
    optLayout.SortOrder = Enum.SortOrder.LayoutOrder
    optLayout.Padding = UDim.new(0, 2)
    optLayout.Parent = optContainer

    local optPad = Instance.new("UIPadding")
    optPad.PaddingLeft = UDim.new(0, 6)
    optPad.PaddingRight = UDim.new(0, 6)
    optPad.PaddingTop = UDim.new(0, 4)
    optPad.PaddingBottom = UDim.new(0, 6)
    optPad.Parent = optContainer

    local optButtons = {}

    local function getSelectedList()
        local list = {}
        for _, opt in ipairs(options) do
            if selected[opt] then table.insert(list, opt) end
        end
        return list
    end

    local function updateHighlights()
        for _, data in ipairs(optButtons) do
            if selected[data.opt] then
                tween(data.btn, {BackgroundColor3 = Theme.Accent, BackgroundTransparency = 0.3}, 0.15)
                data.check.TextTransparency = 0
            else
                tween(data.btn, {BackgroundColor3 = Theme.GlassHover, BackgroundTransparency = 0.5}, 0.15)
                data.check.TextTransparency = 1
            end
        end
        selectedLabel.Text = getSelectedText()
    end

    for i, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Name = "Opt_" .. opt
        optBtn.Text = ""
        optBtn.BackgroundColor3 = selected[opt] and Theme.Accent or Theme.GlassHover
        optBtn.BackgroundTransparency = selected[opt] and 0.3 or 0.5
        optBtn.Size = UDim2.new(1, 0, 0, 24)
        optBtn.AutoButtonColor = false
        optBtn.LayoutOrder = i
        optBtn.Parent = optContainer
        applySmallCorner(optBtn)

        local checkBox = Instance.new("TextLabel")
        checkBox.Text = opt
        checkBox.Font = Theme.Font
        checkBox.TextSize = 12
        checkBox.TextColor3 = Theme.Text
        checkBox.TextXAlignment = Enum.TextXAlignment.Left
        checkBox.BackgroundTransparency = 1
        checkBox.Size = UDim2.new(1, -26, 1, 0)
        checkBox.Position = UDim2.new(0, 8, 0, 0)
        checkBox.Parent = optBtn

        local checkMark = Instance.new("TextLabel")
        checkMark.Name = "Check"
        checkMark.Text = "x"
        checkMark.Font = Theme.FontBold
        checkMark.TextSize = 11
        checkMark.TextColor3 = Theme.Text
        checkMark.BackgroundTransparency = 1
        checkMark.Size = UDim2.new(0, 14, 0, 14)
        checkMark.Position = UDim2.new(1, -20, 0.5, -7)
        checkMark.TextTransparency = selected[opt] and 0 or 1
        checkMark.Parent = optBtn

        table.insert(optButtons, {btn = optBtn, opt = opt, label = checkBox, check = checkMark})

        optBtn.MouseEnter:Connect(function()
            if not selected[opt] then
                tween(optBtn, {BackgroundTransparency = 0.2}, 0.15)
            end
        end)
        optBtn.MouseLeave:Connect(function()
            if not selected[opt] then
                tween(optBtn, {BackgroundTransparency = 0.5}, 0.15)
            end
        end)
        optBtn.MouseButton1Click:Connect(function()
            selected[opt] = not selected[opt]
            updateHighlights()
            if config.Callback then config.Callback(getSelectedList()) end
        end)
    end

    local function closeDropdown()
        open = false
        tween(holder, {Size = UDim2.new(1, 0, 0, 32)}, 0.2)
        tween(pillStroke, {Color = Theme.Border}, 0.15)
        task.delay(0.2, function()
            if not open then optContainer.Visible = false end
        end)
    end

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Text = ""
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Size = UDim2.new(1, 0, 0, 32)
    toggleBtn.ZIndex = 5
    toggleBtn.Parent = holder
    toggleBtn.MouseButton1Click:Connect(function()
        if open then
            closeDropdown()
        else
            open = true
            optContainer.Visible = true
            tween(pillStroke, {Color = Theme.Accent}, 0.15)
            local totalH = 42 + 4 + #options * 26
            tween(holder, {Size = UDim2.new(1, 0, 0, totalH)}, 0.2)
        end
    end)

    local obj = {
        Set = function(_, list)
            selected = {}
            for _, v in ipairs(list) do selected[v] = true end
            updateHighlights()
            if config.Callback then config.Callback(getSelectedList()) end
        end,
        Get = function() return getSelectedList() end,
    }
    local flagKey = config.Flag or (config.Text and (self._name .. "_" .. config.Text) or nil)
    if flagKey then
        self._lib._flags[flagKey] = { type = "MultiDropdown", obj = obj }
    end
    return obj
end

