-- ── Argument serialiser (from richie0866/remote-spy) ──
local _rsCodeify, _rsCodeifyTable, _rsCodeifyTableFlat

local function _rsGetInstancePath(object)
    local path = ""
    local current = object
    local inDataModel = false
    local hasSpecial = function(s) return string.match(s, "^[a-zA-Z0-9_]+$") ~= s end
    repeat
        if current == game then
            path = "game" .. path
            inDataModel = true
        elseif current.Parent == game then
            path = ':GetService(' .. string.format('%q', current.ClassName) .. ')' .. path
        else
            path = (hasSpecial(current.Name) and '["' .. current.Name .. '"]' or '.' .. current.Name) .. path
        end
        current = current.Parent
    until not current
    if not inDataModel then path = "(nil)" .. path end
    path = string.gsub(path, '^game:GetService%("Workspace"%)', "workspace")
    return path
end

local _rsTransformers = {
    table = function(v, lvl) return lvl == -1 and _rsCodeifyTableFlat(v) or _rsCodeifyTable(v, (lvl or 0) + 1) end,
    string = function(v) return string.format("%q", (string.gsub(v, "\n", "\\n"))) end,
    number = function(v) return tostring(v) end,
    boolean = function(v) return tostring(v) end,
    Instance = function(v) return _rsGetInstancePath(v) end,
    BrickColor = function(v) return 'BrickColor.new("' .. v.Name .. '")' end,
    Color3 = function(v) return "Color3.new(" .. v.R .. ", " .. v.G .. ", " .. v.B .. ")" end,
    Vector3 = function(v) return "Vector3.new(" .. v.X .. ", " .. v.Y .. ", " .. v.Z .. ")" end,
    Vector2 = function(v) return "Vector2.new(" .. v.X .. ", " .. v.Y .. ")" end,
    UDim2 = function(v) return "UDim2.new(" .. v.X.Scale .. ", " .. v.X.Offset .. ", " .. v.Y.Scale .. ", " .. v.Y.Offset .. ")" end,
    CFrame = function(v) return "CFrame.new(" .. table.concat({v:GetComponents()}, ", ") .. ")" end,
    Ray = function(v) return "Ray.new(" .. _rsCodeify(v.Origin) .. ", " .. _rsCodeify(v.Direction) .. ")" end,
    EnumItem = function(v) return tostring(v) end,
    NumberRange = function(v) return "NumberRange.new(" .. v.Min .. ", " .. v.Max .. ")" end,
}
_rsCodeify = function(value, level)
    local t = _rsTransformers[typeof(value)]
    if t then return t(value, level or 0) end
    return tostring(value) .. " --[[ " .. typeof(value) .. " ]]"
end
_rsCodeifyTable = function(object, level)
    level = level or 0
    local lines = {}
    local indent = string.rep("\t", level + 1)
    for k, v in pairs(object) do
        if type(v) ~= "function" and type(v) ~= "thread" then
            table.insert(lines, indent .. "[" .. _rsCodeify(k, level) .. "] = " .. _rsCodeify(v, level))
        end
    end
    if #lines == 0 then return "{}" end
    return "{\n" .. table.concat(lines, ",\n") .. "\n" .. string.rep("\t", level) .. "}"
end
_rsCodeifyTableFlat = function(object)
    local lines = {}
    for k, v in pairs(object) do
        if type(v) ~= "function" and type(v) ~= "thread" then
            table.insert(lines, "[" .. _rsCodeify(k, -1) .. "] = " .. _rsCodeify(v, -1))
        end
    end
    if #lines == 0 then return "{}" end
    return "{ " .. table.concat(lines, ", ") .. " }"
end

local function _rsFormatArgs(list)
    local parts = {}
    for i, v in ipairs(list) do
        if i > 12 then table.insert(parts, "..."); break end
        local s = _rsCodeify(v, -1)
        if #s > 200 then s = string.sub(s, 1, 197) .. "..." end
        s = string.gsub(s, "[\n\r\t]+", " ")
        table.insert(parts, s)
    end
    return table.concat(parts, ", ")
end

-- ── Hook installer ──
function Library:_installRemoteSpyHook()
    if self._remoteSpyHooked then return end
    if not hookfunction then
        if self.Notify then
            self:Notify({Text = "Remote Spy: hookfunction not available", Duration = 4})
        end
        return
    end

    self._remoteSpyHooked = true
    self._remoteSpyActive = true
    self._remoteSpyLogs = self._remoteSpyLogs or {}
    self._remoteSpyCounter = self._remoteSpyCounter or 0

    local IsA = game.IsA
    local refs = {}
    local libSelf = self
    local STACK_LEVEL = 4

    local function onReceive(remote, args, isEvent, returns)
        if not libSelf._remoteSpyActive then return end

        local callerScript
        pcall(function()
            if getcallingscript then callerScript = getcallingscript() end
        end)

        -- Walk traceback
        local traceback = {}
        pcall(function()
            local level = STACK_LEVEL
            local fn = debug.info(level, "f")
            while fn do
                table.insert(traceback, fn)
                level = level + 1
                fn = debug.info(level, "f")
            end
        end)

        libSelf._remoteSpyCounter = libSelf._remoteSpyCounter + 1
        local entry = {
            id = libSelf._remoteSpyCounter,
            name = remote.Name,
            className = remote.ClassName,
            path = _rsGetInstancePath(remote),
            remoteType = isEvent and "EVENT" or "FUNCTION",
            args = args,
            argsStr = _rsFormatArgs(args),
            returns = returns,
            returnsStr = returns and _rsFormatArgs(returns) or nil,
            caller = callerScript and tostring(callerScript) or "Unknown",
            traceback = traceback,
            time = os.clock(),
        }

        table.insert(libSelf._remoteSpyLogs, entry)
        -- Cap at 500
        if #libSelf._remoteSpyLogs > 500 then
            table.remove(libSelf._remoteSpyLogs, 1)
        end

        -- Notify UI
        if libSelf._remoteSpy and libSelf._remoteSpy.onNewEntry then
            libSelf._remoteSpy.onNewEntry(entry)
        end
    end

    pcall(function()
        local FireServer = Instance.new("RemoteEvent").FireServer
        refs.FireServer = hookfunction(FireServer, function(self2, ...)
            if self2 and typeof(self2) == "Instance" and IsA(self2, "RemoteEvent") and libSelf._remoteSpyActive then
                task.defer(onReceive, self2, {...}, true)
            end
            return refs.FireServer(self2, ...)
        end)
    end)

    pcall(function()
        local InvokeServer = Instance.new("RemoteFunction").InvokeServer
        refs.InvokeServer = hookfunction(InvokeServer, function(self2, ...)
            local args = {...}
            local results = table.pack(refs.InvokeServer(self2, ...))
            if self2 and typeof(self2) == "Instance" and IsA(self2, "RemoteFunction") and libSelf._remoteSpyActive then
                task.defer(onReceive, self2, args, false, results)
            end
            return table.unpack(results, 1, results.n)
        end)
    end)

    pcall(function()
        if not hookmetamethod or not getnamecallmethod then return end
        refs.__namecall = hookmetamethod(game, "__namecall", function(self2, ...)
            local method = getnamecallmethod()
            local args = {...}
            if libSelf._remoteSpyActive then
                if method == "FireServer" and IsA(self2, "RemoteEvent") then
                    task.defer(onReceive, self2, args, true)
                elseif method == "InvokeServer" and IsA(self2, "RemoteFunction") then
                    local results = table.pack(refs.__namecall(self2, ...))
                    task.defer(onReceive, self2, args, false, results)
                    return table.unpack(results, 1, results.n)
                end
            end
            return refs.__namecall(self2, ...)
        end)
    end)
end

