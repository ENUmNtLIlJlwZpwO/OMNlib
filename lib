function Library:_toggleStringDumper()
    if not self._stringDumper then
        self:_createStringDumper()
        return
    end

    local dump = self._stringDumper
    if dump.open then
        dump.open = false
        tween(dump.frame, {Size = UDim2.new(0, dump.frame.Size.X.Offset, 0, 0)}, 0.3)
        task.delay(0.35, function()
            if not dump.open then
                dump.frame.Visible = false
            end
        end)
    else
        dump.open = true
        dump.frame.Visible = true
        tween(dump.frame, {Size = UDim2.new(0, dump.targetW or dump.frame.Size.X.Offset, 0, dump.targetH)}, 0.3)
    end
end

