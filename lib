function Category:AddKeybind(config)
    config = config or {}
    local col, ci = self:_getColumn(config.Column)
    local order = self:_incOrder(ci)
    local currentKey = config.Default or Enum.KeyCode.Unknown
    local listening = false

    local holder = Instance.new("Frame")
