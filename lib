        local searchText = string.lower(searchBox.Text)
        local con = self._console
        for _, rowData in ipairs(con.logRows) do
            local visible = true
            -- Level filter
            if not con.levelFilter[rowData.level] then
                visible = false
            end
            -- Search filter
            if visible and searchText ~= "" then
                if not string.find(string.lower(rowData.msg), searchText, 1, true) then
                    visible = false
                end
            end
            rowData.frame.Visible = visible
        end
    end

