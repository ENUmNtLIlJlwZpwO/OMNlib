-- ═══════════════════════════════════════════════════
--  CATEGORY: TEXTBOX
-- ═══════════════════════════════════════════════════
function Category:AddTextBox(config)
    config = config or {}
    self._data.order = self._data.order + 1

    local holder = Instance.new("Frame")
    holder.Name = config.Name or "TextBox"
    holder.BackgroundColor3 = Theme.Glass
    holder.BackgroundTransparency = Theme.Transparency
    holder.Size = UDim2.new(1, 0, 0, 34)
    holder.LayoutOrder = self._data.order
    holder.Parent = self._page
    applyGlass(holder)

    local box = Instance.new("TextBox")
    box.PlaceholderText = config.Placeholder or "Type here..."
    box.PlaceholderColor3 = Theme.SubText
    box.Text = config.Default or ""
    box.Font = Theme.Font
    box.TextSize = 14
    box.TextColor3 = Theme.Text
    box.BackgroundTransparency = 1
    box.Size = UDim2.new(1, -24, 1, 0)
    box.Position = UDim2.new(0, 12, 0, 0)
    box.ClearTextOnFocus = false
    box.Parent = holder

    box.Focused:Connect(function()
        local stroke = holder:FindFirstChildOfClass("UIStroke")
        if stroke then tween(stroke, {Color = Theme.Accent, Transparency = 0.2}, 0.2) end
    end)
    box.FocusLost:Connect(function(enterPressed)
        local stroke = holder:FindFirstChildOfClass("UIStroke")
        if stroke then tween(stroke, {Color = Theme.Border, Transparency = Theme.BorderTransp}, 0.2) end
        if enterPressed and config.Callback then config.Callback(box.Text) end
    end)

    return box
end

-- ═══════════════════════════════════════════════════
--  KEYBIND (Toggle visibility)
-- ═══════════════════════════════════════════════════
function Library:SetKeybind(keyCode)
    keyCode = keyCode or Enum.KeyCode.RightShift
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == keyCode then
            self.ScreenGui.Enabled = not self.ScreenGui.Enabled
        end
    end)
end

-- ═══════════════════════════════════════════════════
--  NOTIFICATION
-- ═══════════════════════════════════════════════════
function Library:Notify(config)
    config = config or {}
    local duration = config.Duration or 3

    local notif = Instance.new("Frame")
    notif.Name = "Notification"
    notif.BackgroundColor3 = Theme.Glass
    notif.BackgroundTransparency = Theme.Transparency
    notif.Size = UDim2.new(0, 240, 0, 50)
    notif.Position = UDim2.new(1, 10, 1, -60)
    notif.AnchorPoint = Vector2.new(1, 1)
    notif.Parent = self.ScreenGui
    applyGlass(notif)
    addShadow(notif)

    local text = Instance.new("TextLabel")
    text.Text = config.Text or "Notification"
    text.Font = Theme.Font
    text.TextSize = 13
    text.TextColor3 = Theme.Text
    text.BackgroundTransparency = 1
    text.Size = UDim2.new(1, -20, 1, 0)
    text.Position = UDim2.new(0, 10, 0, 0)
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextWrapped = true
    text.Parent = notif

    tween(notif, {Position = UDim2.new(1, -16, 1, -60)}, 0.3)

    task.delay(duration, function()
        tween(notif, {Position = UDim2.new(1, 10, 1, -60)}, 0.3)
        task.wait(0.35)
        notif:Destroy()
    end)
end

-- ═══════════════════════════════════════════════════
--  DESTROY
-- ═══════════════════════════════════════════════════
function Library:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

return Library
