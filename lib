        if rowData == selectedRowData then
            rowData.frame:SetAttribute("Selected", true)
            rowData.frame.BackgroundColor3 = Theme.Accent
            rowData.frame.BackgroundTransparency = 0.12
        else
            rowData.frame:SetAttribute("Selected", false)
            rowData.frame.BackgroundColor3 = baseColor
            rowData.frame.BackgroundTransparency = 0.5
        end
    end

    local function setDetailEntry(entry)
        local hasEntry = entry ~= nil
        detailEmpty.Visible = not hasEntry
        detailName.Visible = hasEntry
        detailPath.Visible = hasEntry
        detailCaller.Visible = hasEntry
        detailTime.Visible = hasEntry
        detailArgs.Visible = hasEntry
        detailReturns.Visible = hasEntry and entry.returns ~= nil
        detailReplay.Visible = hasEntry

        if not hasEntry then
            detailEmpty.Text = "Select a remote call to inspect it."
            return
        end

        detailName.Text = entry.remoteType .. "  " .. entry.name
        detailPath.Text = "Path: " .. entry.path
        detailCaller.Text = "Caller: " .. entry.caller
        detailTime.Text = "Time: " .. string.format("%.3f", entry.time)
        detailArgs.Text = "Arguments:\n" .. _rsCodeifyTable(entry.args)
        if entry.returns then
            detailReturns.Text = "Returns:\n" .. _rsCodeifyTable(entry.returns)
        else
