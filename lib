--  WATERMARK
-- ═══════════════════════════════════════════════════
function Library:SetWatermark(config)
    config = config or {}
    local text = config.Text or "Glass HUD"

    if self._watermark then self._watermark:Destroy() end

    local wm = Instance.new("Frame")
    wm.Name = "Watermark"
    wm.BackgroundColor3 = Theme.Background
    wm.BackgroundTransparency = 0.15
    wm.Size = UDim2.new(0, 0, 0, 34)
    wm.AutomaticSize = Enum.AutomaticSize.X
    wm.Position = UDim2.new(0, 16, 0, 14)
    wm.ClipsDescendants = false
    wm.Parent = self.ScreenGui
    applySmallCorner(wm)
    local wmStroke = Instance.new("UIStroke")
    wmStroke.Color = Theme.Accent
    wmStroke.Transparency = 0.3
    wmStroke.Thickness = 1.5
    wmStroke.Parent = wm
    self._wmAccentStroke = wmStroke

    local wmPad = Instance.new("UIPadding")
    wmPad.PaddingLeft = UDim.new(0, 10)
    wmPad.PaddingRight = UDim.new(0, 10)
    wmPad.PaddingTop = UDim.new(0, 2)
    wmPad.Parent = wm

    local wmLabel = Instance.new("TextLabel")
    wmLabel.Name = "WmText"
    wmLabel.Text = text
    wmLabel.Font = Theme.Font
    wmLabel.TextSize = 12
    wmLabel.TextColor3 = Theme.SubText
    wmLabel.BackgroundTransparency = 1
    wmLabel.Size = UDim2.new(0, 0, 1, -2)
    wmLabel.AutomaticSize = Enum.AutomaticSize.X
    wmLabel.Parent = wm

    self._watermark = wm
    self._wmLabel = wmLabel
    local defaultContent = config.Content
    if not defaultContent or #defaultContent == 0 then
        defaultContent = {"Name", "FPS", "Ping", "Version"}
    end
    self._wmContent = defaultContent
    self._wmTitle = config.Title or "Glass HUD"

    -- Hide during boot, will be shown after boot animation
    if not self._bootDone then
        wm.Visible = false
    end

    -- Start watermark updater (throttled FPS: every 0.5s)
    if not self._wmUpdaterConn then
        local fpsAccum = 0
        local fpsFrames = 0
        local fpsTimer = 0
        self._wmUpdaterConn = RunService.Heartbeat:Connect(function(dt)
            fpsFrames = fpsFrames + 1
            fpsTimer = fpsTimer + dt
            if fpsTimer >= 0.5 then
                self._wmFps = math.floor(fpsFrames / fpsTimer + 0.5)
                fpsFrames = 0
                fpsTimer = 0
            end
            if self._watermark and self._watermark.Parent and self._watermark.Visible then
                self:_updateWatermarkText()
            end
        end)
    end

    -- Drag watermark
    wm.Active = true
    local wmDragging, wmDragInput, wmDragStart, wmStartPos
    wm.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            wmDragging = true
            wmDragStart = input.Position
            wmStartPos = wm.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then wmDragging = false end
            end)
        end
    end)
    wm.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            wmDragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == wmDragInput and wmDragging then
            local delta = input.Position - wmDragStart
            wm.Position = UDim2.new(
                wmStartPos.X.Scale, wmStartPos.X.Offset + delta.X,
                wmStartPos.Y.Scale, wmStartPos.Y.Offset + delta.Y
            )
        end
    end)

    return {
        SetText = function(_, t) wmLabel.Text = t end,
        Destroy = function() wm:Destroy() end,
    }
end

function Library:_updateWatermarkText()
    if not self._wmLabel then return end
    local parts = {}
    local content = self._wmContent or {"Name", "Version"}
    for _, item in ipairs(content) do
        if item == "Name" then
            table.insert(parts, self._wmTitle or "Glass HUD")
        elseif item == "FPS" then
            table.insert(parts, (self._wmFps or 60) .. " FPS")
        elseif item == "Time" then
            table.insert(parts, os.date("%H:%M:%S"))
        elseif item == "Ping" then
            local ping = math.floor(Players.LocalPlayer:GetNetworkPing() * 1000 + 0.5)
            table.insert(parts, ping .. "ms")
        elseif item == "Version" then
            table.insert(parts, "v1.0")
        end
    end
    self._wmLabel.Text = table.concat(parts, " | ")
end

