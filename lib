function Library:_refreshTextColor(c)
    Theme.Text = c
    Theme.SubText = Color3.fromRGB(
        math.floor(c.R * 255 * 0.55 + 0.5),
        math.floor(c.G * 255 * 0.55 + 0.5),
        math.floor(c.B * 255 * 0.55 + 0.5)
    )
    for _, desc in ipairs(self.ScreenGui:GetDescendants()) do
        if desc:IsA("TextLabel") and desc.Name ~= "Check" and desc.Name ~= "Count"
            and desc.Name ~= "LogTime" and desc.Name ~= "LogTag" and desc.Name ~= "LogMsg"
            and desc.Name ~= "TagText" and desc.Name ~= "StackBadge"
            and desc.Name ~= "RSName" and desc.Name ~= "RSArgs"
            and desc.Name ~= "RSDetailEmpty" and desc.Name ~= "RSDetailPath"
            and desc.Name ~= "RSDetailCaller" and desc.Name ~= "RSDetailTime"
            and desc.Name ~= "RSDetailReturns"
            then
            desc.TextColor3 = c
        end
    end
    for _, tabData in ipairs(self._tabButtons) do
        local lbl = tabData.btn:FindFirstChild("TabLabel")
        local ico = tabData.btn:FindFirstChild("Icon")
        if tabData.name == self._activeCategory then
            if lbl then lbl.TextColor3 = c end
            if ico then ico.ImageColor3 = c end
        else
            if lbl then lbl.TextColor3 = Theme.SubText end
            if ico then ico.ImageColor3 = Theme.SubText end
        end
    end
end

