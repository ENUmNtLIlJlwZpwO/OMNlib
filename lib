function Library:_updateConsoleCounts()
    if not self._console then return end
    local c = self._console
    c.infoCountLabel.Text = "INFO " .. c.infoCount
    c.warnCountLabel.Text = "WARN " .. c.warnCount
    c.errorCountLabel.Text = "ERROR " .. c.errorCount
end

function Library:_addLogEntry(level, message, timestamp)
    if not self._console then return end
    local con = self._console
    local scroll = con.scroll

    -- Fixed log text colors (not theme-dependent)
    local levelColors = {
        info    = Color3.fromRGB(200, 200, 200),
        warn    = Color3.fromRGB(220, 190, 60),
        error   = Color3.fromRGB(220, 70, 70),
    }

    local tagBgColors = {
        info    = Color3.fromRGB(50, 50, 55),
        warn    = Color3.fromRGB(70, 60, 20),
        error   = Color3.fromRGB(70, 25, 25),
    }

    local timeStr = timestamp and os.date("%H:%M:%S", timestamp) or os.date("%H:%M:%S")
    local msgText = message or ""

    con.count = con.count + 1
    local idx = con.count

    -- Update per-level counters
    if level == "info" then
        con.infoCount = con.infoCount + 1
    elseif level == "warn" then
        con.warnCount = con.warnCount + 1
    elseif level == "error" then
        con.errorCount = con.errorCount + 1
    end
    self:_updateConsoleCounts()

    -- Store for export/copy
    table.insert(con.logEntries, {
        time = timeStr,
        level = level,
        msg = msgText,
    })

    -- ── Stack grouping: if same message + level as last, increment counter ──
    if con.lastLogMsg == msgText and con.lastLogLevel == level and con.lastLogRow then
        con.lastLogStackCount = con.lastLogStackCount + 1
        local badge = con.lastLogRow:FindFirstChild("StackBadge")
        if badge then
            badge.Text = "×" .. con.lastLogStackCount
            badge.Visible = true
        end
        -- Update time on last row
        local tl = con.lastLogRow:FindFirstChild("LogTime")
        if tl then tl.Text = timeStr end
