    holder.BackgroundColor3 = Theme.Glass
    holder.BackgroundTransparency = Theme.Transparency
    holder.Size = UDim2.new(1, 0, 0, 32)
    holder.LayoutOrder = order
    holder.Parent = col
    applyGlass(holder)

    local label = Instance.new("TextLabel")
    label.Text = config.Text or "Keybind"
    label.Font = Theme.Font
    label.TextSize = 13
    label.TextColor3 = Theme.Text
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -80, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder

    local keyName = (currentKey ~= Enum.KeyCode.Unknown) and currentKey.Name or "..."
    local keyBtn = Instance.new("TextButton")
    keyBtn.Name = "KeyBtn"
    keyBtn.Text = keyName
    keyBtn.Font = Theme.Font
    keyBtn.TextSize = 11
    keyBtn.TextColor3 = Theme.Text
    keyBtn.BackgroundColor3 = Theme.ToggleOff
    keyBtn.BackgroundTransparency = 0
    keyBtn.Size = UDim2.new(0, 60, 0, 22)
    keyBtn.Position = UDim2.new(1, -68, 0, 5)
    keyBtn.AutoButtonColor = false
    keyBtn.Parent = holder
    Instance.new("UICorner", keyBtn).CornerRadius = UDim.new(0, 5)
    local keyStroke = Instance.new("UIStroke")
    keyStroke.Color = Theme.Border
    keyStroke.Transparency = 0.2
    keyStroke.Thickness = 1
    keyStroke.Parent = keyBtn

    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        keyBtn.Text = "..."
        tween(keyStroke, {Color = Theme.Accent}, 0.15)
        tween(keyBtn, {BackgroundColor3 = Theme.GlassHover}, 0.15)
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if not listening then
            -- Fire callback when key is pressed
            if currentKey ~= Enum.KeyCode.Unknown and input.KeyCode == currentKey and not processed then
                if config.Callback then config.Callback(currentKey) end
            end
            return
        end
        if input.UserInputType == Enum.UserInputType.Keyboard then
            if input.KeyCode == Enum.KeyCode.Escape then
                -- Cancel / unbind
                currentKey = Enum.KeyCode.Unknown
                keyBtn.Text = "None"
            else
                currentKey = input.KeyCode
                keyBtn.Text = currentKey.Name
            end
            listening = false
            tween(keyStroke, {Color = Theme.Border}, 0.15)
            tween(keyBtn, {BackgroundColor3 = Theme.ToggleOff}, 0.15)
            if config.OnChanged then config.OnChanged(currentKey) end
        end
    end)

    return {
        Set = function(_, key)
            currentKey = key
            keyBtn.Text = (key ~= Enum.KeyCode.Unknown) and key.Name or "None"
        end,
        Get = function() return currentKey end,
    }
end

