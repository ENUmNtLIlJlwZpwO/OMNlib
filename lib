function Library:_serializeFlags()
    local data = {}
    for flag, info in pairs(self._flags) do
        local t = info.type
        local obj = info.obj
        local ok, result = pcall(function()
            if t == "Toggle" then
                return { type = t, value = obj.Get() }
            elseif t == "Slider" then
                return { type = t, value = obj.Get() }
            elseif t == "Dropdown" then
                return { type = t, value = obj.Get() }
            elseif t == "MultiDropdown" then
                return { type = t, value = obj.Get() }
            elseif t == "ColorPicker" then
                local c, a = obj.Get()
                return { type = t, value = { c.R, c.G, c.B }, alpha = a }
            elseif t == "Keybind" then
                local key = obj.Get()
                return { type = t, value = key.Name }
            elseif t == "TextBox" then
                return { type = t, value = obj.Get() }
            end
        end)
        if ok and result then
            data[flag] = result
        end
    end
    return data
end

function Library:_deserializeFlags(data)
    for flag, info in pairs(data) do
        local registered = self._flags[flag]
        if registered then
            pcall(function()
                local t = info.type
                local obj = registered.obj
                if t == "Toggle" then
                    obj:Set(info.value)
                elseif t == "Slider" then
                    obj:Set(info.value)
                elseif t == "Dropdown" then
                    obj:Set(info.value)
                elseif t == "MultiDropdown" then
                    obj:Set(info.value)
                elseif t == "ColorPicker" then
                    local v = info.value
                    obj:Set(Color3.new(v[1], v[2], v[3]), info.alpha)
                elseif t == "Keybind" then
                    local key = Enum.KeyCode[info.value]
                    if key then obj:Set(key) end
                elseif t == "TextBox" then
                    obj:Set(info.value)
                end
            end)
        end
    end
end

function Library:SaveConfig(name)
    if type(writefile) ~= "function" then
        if self.Notify then self:Notify({ Text = "Config save unavailable: writefile missing", Duration = 4 }) end
        return false
    end
    if type(isfolder) == "function" and not isfolder(self._configFolder) then
        if type(makefolder) == "function" then makefolder(self._configFolder) end
    end
    local data = self:_serializeFlags()
    local ok, json = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok then
        if self.Notify then self:Notify({ Text = "Config save failed: encode error", Duration = 4 }) end
        return false
    end
    writefile(self._configFolder .. "/" .. name .. ".json", json)
    if self.Notify then self:Notify({ Text = "Config saved: " .. name, Duration = 3 }) end
    return true
end

function Library:LoadConfig(name)
    if type(readfile) ~= "function" or type(isfile) ~= "function" then
        if self.Notify then self:Notify({ Text = "Config load unavailable: file system missing", Duration = 4 }) end
        return false
    end
    local path = self._configFolder .. "/" .. name .. ".json"
    if not isfile(path) then
        if self.Notify then self:Notify({ Text = "Config not found: " .. name, Duration = 3 }) end
        return false
    end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok or type(data) ~= "table" then
        if self.Notify then self:Notify({ Text = "Failed to parse config: " .. name, Duration = 4 }) end
        return false
    end
    self:_deserializeFlags(data)
    if self.Notify then self:Notify({ Text = "Config loaded: " .. name, Duration = 3 }) end
    return true
end

function Library:DeleteConfig(name)
    if type(delfile) ~= "function" then
        if self.Notify then self:Notify({ Text = "Config delete unavailable", Duration = 4 }) end
        return false
    end
    local path = self._configFolder .. "/" .. name .. ".json"
    if type(isfile) == "function" and isfile(path) then
        delfile(path)
        if self.Notify then self:Notify({ Text = "Config deleted: " .. name, Duration = 3 }) end
        return true
    end
    return false
end

function Library:GetConfigs()
    if type(listfiles) ~= "function" then return {} end
    if type(isfolder) == "function" and not isfolder(self._configFolder) then return {} end
    local ok, files = pcall(listfiles, self._configFolder)
    if not ok then return {} end
    local configs = {}
    for _, file in ipairs(files) do
        local name = string.match(file, "([^/\\]+)%.json$")
        if name then
            table.insert(configs, name)
        end
    end
    return configs
end

function Library:ExportConfig()
    local data = self:_serializeFlags()
    local ok, json = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok then
        if self.Notify then self:Notify({ Text = "Export failed: encode error", Duration = 4 }) end
        return
    end
    if setclipboard then
        setclipboard(json)
    elseif toclipboard then
        toclipboard(json)
    end
    if self.Notify then self:Notify({ Text = "Config exported to clipboard", Duration = 3 }) end
    return json
end

function Library:ImportConfig(json)
    if type(json) ~= "string" or json == "" then
        if self.Notify then self:Notify({ Text = "No data to import", Duration = 3 }) end
        return false
    end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(json)
    end)
    if not ok or type(data) ~= "table" then
        if self.Notify then self:Notify({ Text = "Failed to parse imported config", Duration = 4 }) end
        return false
    end
    self:_deserializeFlags(data)
    if self.Notify then self:Notify({ Text = "Config imported successfully", Duration = 3 }) end
    return true
end

