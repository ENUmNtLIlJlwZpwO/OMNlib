function Library:_collectStringDumpData()
    if type(getgc) ~= "function" then
        return nil, "getgc missing"
    end

    local entries = {}
    local seen = {}

    for _, value in next, getgc(true) do
        if type(value) == "table" then
            for key, innerValue in next, value do
                local valueType = type(innerValue)
                if type(key) == "string" and (valueType == "number" or valueType == "boolean") then
                    local line = "String: " .. key .. " | Value: " .. tostring(innerValue) .. " | Type: " .. valueType
                    if not seen[line] then
                        seen[line] = true
                        table.insert(entries, {
                            key = key,
                            value = tostring(innerValue),
                            valueType = valueType,
                            line = line,
                        })
                    end
                end
            end
        end
    end

    table.sort(entries, function(a, b)
        if a.key == b.key then
            return a.line < b.line
        end
        return a.key < b.key
    end)

    return entries
end

