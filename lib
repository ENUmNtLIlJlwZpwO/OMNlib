function Library:_toggleConsole()
    if not self._console then
        self:_createConsole()
        return
    end

    local con = self._console
    if con.open then
        con.open = false
        tween(con.frame, {Size = UDim2.new(0, con.frame.Size.X.Offset, 0, 0)}, 0.3)
        task.delay(0.35, function()
            if not con.open then
                con.frame.Visible = false
            end
        end)
    else
        con.open = true
        con.frame.Visible = true
        tween(con.frame, {Size = UDim2.new(0, con.targetW or con.frame.Size.X.Offset, 0, con.targetH)}, 0.3)
    end
end

-- ═══════════════════════════════════════════════════
--  NOTIFICATION (stacking duplicates)
-- ═══════════════════════════════════════════════════
function Library:Notify(config)
    config = config or {}
    local duration = config.Duration or 3
    local msg = config.Text or "Notification"

    -- Init notification tracking
    if not self._notifications then self._notifications = {} end
    if not self._notifStack then self._notifStack = {} end

    -- Check for duplicate: if same message exists, increment counter
    for _, data in ipairs(self._notifStack) do
        if data.msg == msg and data.frame and data.frame.Parent then
            data.count = data.count + 1
            local countLabel = data.frame:FindFirstChild("Count")
            if countLabel then
                countLabel.Text = "x" .. data.count
                countLabel.Visible = true
            end
            -- Reset timer
            data.expiry = tick() + duration
            return
        end
    end

    -- Calculate position based on existing notifications
    local index = #self._notifications
    local yOffset = -10 - index * 56

    local notif = Instance.new("Frame")
    notif.Name = "Notification"
    notif.BackgroundColor3 = Theme.Glass
    notif.BackgroundTransparency = Theme.Transparency
    notif.Size = UDim2.new(0, 240, 0, 46)
    notif.Position = UDim2.new(1, 10, 1, yOffset)
    notif.AnchorPoint = Vector2.new(1, 1)
    notif.Parent = self.ScreenGui
    applyGlass(notif)
    addShadow(notif)

    local text = Instance.new("TextLabel")
    text.Text = msg
    text.Font = Theme.Font
    text.TextSize = 13
    text.TextColor3 = Theme.Text
    text.BackgroundTransparency = 1
    text.Size = UDim2.new(1, -50, 1, 0)
    text.Position = UDim2.new(0, 10, 0, 0)
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextWrapped = true
    text.Parent = notif

    local countLabel = Instance.new("TextLabel")
    countLabel.Name = "Count"
    countLabel.Text = "x1"
    countLabel.Font = Theme.FontBold
    countLabel.TextSize = 11
    countLabel.TextColor3 = Theme.Accent
    countLabel.BackgroundTransparency = 1
    countLabel.Size = UDim2.new(0, 30, 1, 0)
    countLabel.Position = UDim2.new(1, -36, 0, 0)
    countLabel.TextXAlignment = Enum.TextXAlignment.Right
    countLabel.Visible = false
    countLabel.Parent = notif

    local stackData = {msg = msg, frame = notif, count = 1, expiry = tick() + duration}
    table.insert(self._notifStack, stackData)
    table.insert(self._notifications, notif)

    -- Slide in
    tween(notif, {Position = UDim2.new(1, -16, 1, yOffset)}, 0.3)

    local libSelf = self
    local function removeNotif()
        -- Find and remove from tracking
        for i, n in ipairs(libSelf._notifications) do
            if n == notif then
                table.remove(libSelf._notifications, i)
                break
            end
        end
        for i, data in ipairs(libSelf._notifStack) do
            if data.frame == notif then
                table.remove(libSelf._notifStack, i)
                break
            end
        end
        -- Slide out
        local curPos = notif.Position
        tween(notif, {Position = UDim2.new(1, 10, curPos.Y.Scale, curPos.Y.Offset)}, 0.3)
        task.wait(0.35)
        notif:Destroy()
        -- Reposition remaining notifications
        for i, n in ipairs(libSelf._notifications) do
            local newY = -10 - (i - 1) * 56
            tween(n, {Position = UDim2.new(1, -16, 1, newY)}, 0.25)
        end
    end

    -- Auto-remove with timer check (supports reset from stacking)
    task.spawn(function()
        while stackData.frame and stackData.frame.Parent do
            if tick() >= stackData.expiry then
                removeNotif()
                return
            end
            task.wait(0.5)
        end
    end)
end

