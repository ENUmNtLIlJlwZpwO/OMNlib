    local function buildReplayCode(entry)
        local code = "local remote = " .. entry.path .. "\nlocal arguments = " .. _rsCodeifyTable(entry.args)
        if entry.remoteType == "EVENT" then
            code = code .. "\nremote:FireServer(unpack(arguments))"
        else
            code = code .. "\nlocal results = remote:InvokeServer(unpack(arguments))"
        end
        return code
    end

    local function refreshRowVisual(rowData)
        local index = tonumber(string.match(rowData.frame.Name, "^RS_(%d+)$")) or 1
