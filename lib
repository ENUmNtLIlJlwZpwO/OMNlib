        end
        local lines = {}
        for _, rd in ipairs(rows) do
            if rd.frame.Visible then
                local e = rd.entry
                table.insert(lines, "[" .. e.remoteType .. "] " .. e.name .. " — " .. e.path)
                table.insert(lines, "  Caller: " .. e.caller)
                table.insert(lines, "  Args: " .. e.argsStr)
                if e.returnsStr then
                    table.insert(lines, "  Returns: " .. e.returnsStr)
                end
                table.insert(lines, "  Code:")
                table.insert(lines, "    local remote = " .. e.path)
                table.insert(lines, "    local arguments = " .. _rsCodeifyTable(e.args))
