                    end
                end
                table.insert(lines, "")
            end
        end
        local fileName = "RemoteSpy_" .. os.date("%Y%m%d_%H%M%S") .. ".lua"
        writefile(fileName, table.concat(lines, "\n"))
        if self.Notify then self:Notify({Text = "Remote Spy exported: " .. fileName, Duration = 3}) end
