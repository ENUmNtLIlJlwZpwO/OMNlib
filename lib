--  CHANGELOG MODAL
-- ═══════════════════════════════════════════════════
function Library:ShowChangelog(config)
    config = config or {}
    local title = config.Title or "Changelog"
    local entries = config.Entries or {}
    local version = config.Version or "1.0.0"

    self._changelogOpen = true

    -- Reuse boot overlay if available, otherwise create new one
    local changelogGui, overlay
    if self._overlayGui and self._overlayFrame then
        changelogGui = self._overlayGui
        overlay = self._overlayFrame
        overlay.ZIndex = 80
    else
        changelogGui = Instance.new("ScreenGui")
        changelogGui.Name = "ChangelogScreen"
        changelogGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        changelogGui.IgnoreGuiInset = true
        changelogGui.ResetOnSpawn = false
        changelogGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

        overlay = Instance.new("Frame")
        overlay.Name = "ChangelogOverlay"
        overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        overlay.BackgroundTransparency = 1
        overlay.Size = UDim2.new(1, 0, 1, 0)
        overlay.ZIndex = 80
        overlay.Parent = changelogGui

        tween(overlay, {BackgroundTransparency = 0.5}, 0.25)
    end

    -- Modal card
    local modal = Instance.new("Frame")
    modal.Name = "ChangelogModal"
    modal.BackgroundColor3 = Theme.Background
    modal.BackgroundTransparency = 0.05
    modal.Size = UDim2.new(0, 0, 0, 0)
    modal.Position = UDim2.new(0.5, 0, 0.5, 0)
    modal.AnchorPoint = Vector2.new(0.5, 0.5)
    modal.ClipsDescendants = true
    modal.ZIndex = 81
    modal.Parent = changelogGui
    Instance.new("UICorner", modal).CornerRadius = Theme.CornerRadius

    local modalStroke = Instance.new("UIStroke")
    modalStroke.Color = Theme.Accent
    modalStroke.Transparency = 0.3
    modalStroke.Thickness = 1
    modalStroke.Parent = modal
    addShadow(modal)

    tween(modal, {Size = UDim2.new(0, 340, 0, 280)}, 0.35)
    task.wait(0.35)

    -- Header bar
    local header = Instance.new("Frame")
    header.Name = "Header"
    header.BackgroundColor3 = Theme.Glass
    header.BackgroundTransparency = 0.3
    header.Size = UDim2.new(1, 0, 0, 38)
    header.ZIndex = 82
    header.Parent = modal
    Instance.new("UICorner", header).CornerRadius = Theme.CornerRadius

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Text = title
    titleLabel.Font = Theme.FontBold
    titleLabel.TextSize = 15
    titleLabel.TextColor3 = Theme.Text
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -90, 1, 0)
    titleLabel.Position = UDim2.new(0, 14, 0, 0)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.ZIndex = 83
    titleLabel.Parent = header

    local versionLabel = Instance.new("TextLabel")
    versionLabel.Text = "v" .. version
    versionLabel.Font = Theme.Font
    versionLabel.TextSize = 11
    versionLabel.TextColor3 = Theme.Accent
    versionLabel.BackgroundTransparency = 1
    versionLabel.Size = UDim2.new(0, 60, 1, 0)
    versionLabel.Position = UDim2.new(1, -100, 0, 0)
    versionLabel.TextXAlignment = Enum.TextXAlignment.Right
    versionLabel.ZIndex = 83
    versionLabel.Parent = header

    -- Close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Text = "x"
    closeBtn.Font = Theme.Font
    closeBtn.TextSize = 18
    closeBtn.TextColor3 = Theme.SubText
    closeBtn.BackgroundTransparency = 1
    closeBtn.Size = UDim2.new(0, 38, 0, 38)
    closeBtn.Position = UDim2.new(1, -38, 0, 0)
    closeBtn.ZIndex = 84
    closeBtn.Parent = header

    -- Scrolling content
    local content = Instance.new("ScrollingFrame")
    content.Name = "Content"
    content.BackgroundTransparency = 1
    content.Size = UDim2.new(1, -16, 1, -50)
    content.Position = UDim2.new(0, 8, 0, 44)
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.ScrollBarThickness = 2
    content.ScrollBarImageColor3 = Theme.Accent
    content.ScrollBarImageTransparency = 0.5
    content.ScrollingDirection = Enum.ScrollingDirection.Y
    content.ZIndex = 82
    content.Parent = modal

    local contentLayout = Instance.new("UIListLayout")
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0, 8)
    contentLayout.Parent = content

    local contentPad = Instance.new("UIPadding")
    contentPad.PaddingTop = UDim.new(0, 4)
    contentPad.PaddingBottom = UDim.new(0, 8)
    contentPad.PaddingLeft = UDim.new(0, 4)
    contentPad.PaddingRight = UDim.new(0, 4)
    contentPad.Parent = content

    -- Build entries
    for i, entry in ipairs(entries) do
        local entryFrame = Instance.new("Frame")
        entryFrame.Name = "Entry_" .. i
        entryFrame.BackgroundColor3 = Theme.Glass
        entryFrame.BackgroundTransparency = 0.4
        entryFrame.Size = UDim2.new(1, 0, 0, 0)
        entryFrame.AutomaticSize = Enum.AutomaticSize.Y
        entryFrame.LayoutOrder = i
        entryFrame.ZIndex = 82
        entryFrame.Parent = content
        Instance.new("UICorner", entryFrame).CornerRadius = Theme.CornerSmall

        local entryPad = Instance.new("UIPadding")
        entryPad.PaddingTop = UDim.new(0, 6)
        entryPad.PaddingBottom = UDim.new(0, 6)
        entryPad.PaddingLeft = UDim.new(0, 8)
        entryPad.PaddingRight = UDim.new(0, 8)
        entryPad.Parent = entryFrame

        local entryLayout = Instance.new("UIListLayout")
        entryLayout.SortOrder = Enum.SortOrder.LayoutOrder
        entryLayout.Padding = UDim.new(0, 3)
        entryLayout.Parent = entryFrame

        -- Entry header / date
        if entry.Date then
            local dateLabel = Instance.new("TextLabel")
            dateLabel.Text = entry.Date
            dateLabel.Font = Theme.FontBold
            dateLabel.TextSize = 11
            dateLabel.TextColor3 = Theme.Accent
            dateLabel.BackgroundTransparency = 1
            dateLabel.Size = UDim2.new(1, 0, 0, 14)
            dateLabel.TextXAlignment = Enum.TextXAlignment.Left
            dateLabel.LayoutOrder = 1
            dateLabel.ZIndex = 83
            dateLabel.Parent = entryFrame
        end

        if entry.Title then
            local eTitleLabel = Instance.new("TextLabel")
            eTitleLabel.Text = entry.Title
            eTitleLabel.Font = Theme.FontBold
            eTitleLabel.TextSize = 13
            eTitleLabel.TextColor3 = Theme.Text
            eTitleLabel.BackgroundTransparency = 1
            eTitleLabel.Size = UDim2.new(1, 0, 0, 16)
            eTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
            eTitleLabel.LayoutOrder = 2
            eTitleLabel.ZIndex = 83
            eTitleLabel.Parent = entryFrame
        end

        -- Changes list
        if entry.Changes then
            for j, change in ipairs(entry.Changes) do
                local tag = change.Tag or "fix"
                local tagColors = {
                    add = Color3.fromRGB(80, 190, 80),
                    fix = Color3.fromRGB(80, 140, 220),
                    remove = Color3.fromRGB(200, 80, 80),
                    change = Color3.fromRGB(200, 180, 60),
                }

                local row = Instance.new("Frame")
                row.Name = "Change_" .. j
                row.BackgroundTransparency = 1
                row.Size = UDim2.new(1, 0, 0, 16)
                row.LayoutOrder = 10 + j
                row.ZIndex = 83
                row.Parent = entryFrame

                local tagLabel = Instance.new("TextLabel")
                tagLabel.Text = string.upper(tag)
                tagLabel.Font = Theme.FontBold
                tagLabel.TextSize = 9
                tagLabel.TextColor3 = tagColors[tag] or Theme.SubText
                tagLabel.BackgroundColor3 = tagColors[tag] or Theme.SubText
                tagLabel.BackgroundTransparency = 0.85
                tagLabel.Size = UDim2.new(0, 50, 0, 14)
                tagLabel.Position = UDim2.new(0, 0, 0, 1)
                tagLabel.ZIndex = 84
                tagLabel.Parent = row
                Instance.new("UICorner", tagLabel).CornerRadius = UDim.new(0, 3)

                local changeLabel = Instance.new("TextLabel")
                changeLabel.Text = change.Text or ""
                changeLabel.Font = Theme.Font
                changeLabel.TextSize = 11
                changeLabel.TextColor3 = Theme.Text
                changeLabel.BackgroundTransparency = 1
                changeLabel.Size = UDim2.new(1, -58, 0, 16)
                changeLabel.Position = UDim2.new(0, 56, 0, 0)
                changeLabel.TextXAlignment = Enum.TextXAlignment.Left
                changeLabel.TextWrapped = true
                changeLabel.AutomaticSize = Enum.AutomaticSize.Y
                changeLabel.ZIndex = 84
                changeLabel.Parent = row
                row.AutomaticSize = Enum.AutomaticSize.Y
            end
        end
    end

    -- Fade in entries
    for _, child in ipairs(content:GetChildren()) do
        if child:IsA("Frame") then
            child.BackgroundTransparency = 1
            tween(child, {BackgroundTransparency = 0.4}, 0.3)
        end
    end

    -- Close function
    local libSelf = self
    local function closeModal()
        tween(modal, {Size = UDim2.new(0, 340, 0, 0)}, 0.3)
        tween(modalStroke, {Transparency = 1}, 0.25)
        tween(overlay, {BackgroundTransparency = 1}, 0.3)
        task.wait(0.35)
        changelogGui:Destroy()
        libSelf._changelogOpen = false
        libSelf._overlayGui = nil
        libSelf._overlayFrame = nil
    end

    closeBtn.MouseEnter:Connect(function() tween(closeBtn, {TextColor3 = Color3.fromRGB(255, 80, 80)}, 0.15) end)
    closeBtn.MouseLeave:Connect(function() tween(closeBtn, {TextColor3 = Theme.SubText}, 0.15) end)
    closeBtn.MouseButton1Click:Connect(closeModal)
    overlay.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            closeModal()
        end
    end)
end

