function Library:SetCustomCursor(style)
    -- Destroy previous cursor
    if self._cursor then
        self._cursor:Destroy()
        self._cursor = nil
    end
    if self._cursorConn then
        self._cursorConn:Disconnect()
        self._cursorConn = nil
    end

    if style and style ~= "None" and CursorStyles[style] then
        local cursor = CursorStyles[style](self.ScreenGui)
        self._cursor = cursor
        self._cursorStyle = style

        local mouse = Players.LocalPlayer:GetMouse()
        self._cursorConn = RunService.RenderStepped:Connect(function()
            if self._cursor and self._cursor.Parent then
                self._cursor.Position = UDim2.new(0, mouse.X, 0, mouse.Y)
            end
        end)

        cursor.Visible = true
        UserInputService.MouseIconEnabled = false
    else
        self._cursorStyle = "None"
        UserInputService.MouseIconEnabled = true
    end
end

function Library:_updateCursorAccent()
    if not self._cursor then return end
    local style = self._cursorStyle
    if style == "Circle" then
        self._cursor.BackgroundColor3 = Theme.Accent
    elseif style == "Ring" then
        local s = self._cursor:FindFirstChildOfClass("UIStroke")
        if s then s.Color = Theme.Accent end
        local d = self._cursor:FindFirstChild("Dot")
        if d then d.BackgroundColor3 = Theme.Accent end
    elseif style == "Cross" then
        local h = self._cursor:FindFirstChild("H")
        local v = self._cursor:FindFirstChild("V")
        if h then h.BackgroundColor3 = Theme.Accent end
        if v then v.BackgroundColor3 = Theme.Accent end
    elseif style == "Diamond" then
        self._cursor.BackgroundColor3 = Theme.Accent
    elseif style == "Square" then
        local s = self._cursor:FindFirstChildOfClass("UIStroke")
        if s then s.Color = Theme.Accent end
        local d = self._cursor:FindFirstChild("Dot")
        if d then d.BackgroundColor3 = Theme.Accent end
    end
end

function Library:_refreshAccent(c)
    for _, catData in pairs(self._categories) do
        for _, col in ipairs(catData.cols) do
            local function updateChildren(parent)
                for _, child in ipairs(parent:GetChildren()) do
                    local checkBox = child:FindFirstChild("CheckBox")
                    if checkBox then
                        local checkLabel = checkBox:FindFirstChild("Check")
                        if checkLabel and checkLabel.TextTransparency < 0.5 then
                            checkBox.BackgroundColor3 = c
                            local stroke = checkBox:FindFirstChildOfClass("UIStroke")
                            if stroke then stroke.Color = c end
                        end
                    end
                    local trackBg = child:FindFirstChild("TrackBg")
                    if trackBg then
                        local fill = trackBg:FindFirstChild("Fill")
                        if fill then
                            fill.BackgroundColor3 = c
                        end
                    end
                    local ddBar = child:FindFirstChild("AccentBar")
                    if ddBar then
                        ddBar.BackgroundColor3 = c
                    end
                    if child:IsA("Frame") and child:FindFirstChild("GBTitle") then
                        updateChildren(child)
                    end
                end
            end
            updateChildren(col)
        end
    end
end

function Library:_refreshGlass()
    -- Update TabBar
    local tabBar = self._tabScroll and self._tabScroll.Parent
    if tabBar then
        tabBar.BackgroundColor3 = Theme.TabBg
        local tbStroke = tabBar:FindFirstChildOfClass("UIStroke")
        if tbStroke then tbStroke.Color = Theme.Border end
    end

    -- Update tab buttons
    for _, tabData in ipairs(self._tabButtons) do
        local btn = tabData.btn
        if tabData.name == self._activeCategory then
            btn.BackgroundColor3 = Theme.TabActive
        else
            btn.BackgroundColor3 = Theme.TabInactive
        end
    end

    -- Update all descendants: Glass frames, strokes, toggle off, dropdown options, etc.
    for _, desc in ipairs(self.ScreenGui:GetDescendants()) do
        if desc:IsA("UIStroke") and desc.Name ~= "AccentBar" then
            -- Skip strokes on active toggle checkboxes and watermark
            local p = desc.Parent
            if p and p.Name == "CheckBox" then
                local check = p:FindFirstChild("Check")
                if check and check.TextTransparency < 0.5 then
                    -- Active toggle, keep accent color
                else
                    desc.Color = Theme.Border
                    desc.Transparency = Theme.BorderTransp
                end
            elseif p and p.Name == "Watermark" then
                -- Watermark stroke is accent, skip
            elseif p and p.Name == "KeyBtn" then
                desc.Color = Theme.SubText
                desc.Transparency = 0.1
            else
                desc.Color = Theme.Border
                desc.Transparency = Theme.BorderTransp
            end
        end
    end

    for _, catData in pairs(self._categories) do
        for _, col in ipairs(catData.cols) do
            local function updateGlass(parent)
                for _, child in ipairs(parent:GetChildren()) do
                    -- Update Glass-colored backgrounds (buttons, toggles, dropdowns, sliders, etc.)
                    if (child:IsA("Frame") or child:IsA("TextButton")) and child.BackgroundTransparency < 1 then
                        local name = child.Name
                        if name == "CheckBox" then
                            local check = child:FindFirstChild("Check")
                            if not check or check.TextTransparency > 0.5 then
                                child.BackgroundColor3 = Theme.ToggleOff
                            end
                        elseif name == "SelectedPill" then
                            child.BackgroundColor3 = Theme.TabInactive
                        elseif name == "AccentBar" or name == "Fill" or name == "Cursor" or name == "HueCursor" or name == "OpacityKnob" or name == "Preview" or name == "Dot" or name == "CustomCursor" or name == "Knob" then
                            -- Skip accent/special colored elements
                        elseif name == "TrackBg" or name == "OpacityTrack" then
                            child.BackgroundColor3 = Theme.ToggleOff
                        elseif child.Name:sub(1, 4) == "Opt_" then
                            -- Dropdown option: check if selected
                            if child.BackgroundTransparency <= 0.3 then
                                child.BackgroundColor3 = Theme.Accent
                            else
                                child.BackgroundColor3 = Theme.GlassHover
                            end
                        elseif name == "GBSep" then
                            child.BackgroundColor3 = Theme.Border
                        elseif name == "KeyBtn" then
                            child.BackgroundColor3 = Theme.ToggleOff
                        elseif name == "Btn" or name == "Shadow" then
                            -- Skip inner button/shadow
                        else
                            child.BackgroundColor3 = Theme.Glass
                        end
                    end
                    -- Recurse into all Frame children to find nested elements
                    if child:IsA("Frame") or child:IsA("ScrollingFrame") then
                        updateGlass(child)
                    end
                end
            end
            updateGlass(col)
        end
    end

    -- Update title bar
    local titleBar = self.Main:FindFirstChild("TitleBar")
    if titleBar then
        titleBar.BackgroundColor3 = Theme.Glass
    end
end

function Library:_refreshTextColor(c)
    Theme.Text = c
    Theme.SubText = Color3.fromRGB(
        math.floor(c.R * 255 * 0.55 + 0.5),
        math.floor(c.G * 255 * 0.55 + 0.5),
        math.floor(c.B * 255 * 0.55 + 0.5)
    )
    for _, desc in ipairs(self.ScreenGui:GetDescendants()) do
        if desc:IsA("TextLabel") and desc.Name ~= "Check" and desc.Name ~= "Count" then
            desc.TextColor3 = c
        end
    end
    for _, tabData in ipairs(self._tabButtons) do
        local lbl = tabData.btn:FindFirstChild("TabLabel")
        local ico = tabData.btn:FindFirstChild("Icon")
        if tabData.name == self._activeCategory then
            if lbl then lbl.TextColor3 = c end
            if ico then ico.ImageColor3 = c end
        else
            if lbl then lbl.TextColor3 = Theme.SubText end
            if ico then ico.ImageColor3 = Theme.SubText end
        end
    end
end

