--  CATEGORY: SLIDER
-- ═══════════════════════════════════════════════════
function Category:AddSlider(config)
    config = config or {}
    local col, ci = self:_getColumn(config.Column)
    local order = self:_incOrder(ci)
    local min = config.Min or 0
    local max = config.Max or 100
    local value = math.clamp(config.Default or min, min, max)

    local holder = Instance.new("Frame")
    holder.Name = config.Name or "Slider"
    holder.BackgroundColor3 = Theme.Glass
    holder.BackgroundTransparency = Theme.Transparency
    holder.Size = UDim2.new(1, 0, 0, 46)
    holder.LayoutOrder = order
    holder.Parent = col
    applyGlass(holder)

    local label = Instance.new("TextLabel")
    label.Text = config.Text or "Slider"
    label.Font = Theme.Font
    label.TextSize = 12
    label.TextColor3 = Theme.Text
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -50, 0, 18)
    label.Position = UDim2.new(0, 10, 0, 4)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder

    local valLabel = Instance.new("TextBox")
    valLabel.Name = "Value"
    valLabel.Text = tostring(value)
    valLabel.Font = Theme.Font
    valLabel.TextSize = 12
    valLabel.TextColor3 = Theme.SubText
    valLabel.BackgroundTransparency = 1
    valLabel.Size = UDim2.new(0, 40, 0, 18)
    valLabel.Position = UDim2.new(1, -48, 0, 4)
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.ClearTextOnFocus = true
    valLabel.Parent = holder

    local trackBg = Instance.new("Frame")
    trackBg.Name = "TrackBg"
    trackBg.BackgroundColor3 = Theme.ToggleOff
    trackBg.Size = UDim2.new(1, -20, 0, 6)
    trackBg.Position = UDim2.new(0, 10, 0, 30)
    trackBg.Parent = holder
    Instance.new("UICorner", trackBg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.BackgroundColor3 = Theme.Accent
    local pct = (value - min) / (max - min)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.Parent = trackBg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(pct, -6, 0.5, -6)
    knob.ZIndex = 3
    knob.Parent = trackBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local knobStroke = Instance.new("UIStroke")
    knobStroke.Name = "KnobStroke"
    knobStroke.Color = Theme.Border
    knobStroke.Transparency = 0.3
    knobStroke.Thickness = 1
    knobStroke.Parent = knob

    local function setVal(v)
        value = math.clamp(v, min, max)
        local p = (value - min) / (max - min)
        fill.Size = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, -6, 0.5, -6)
        valLabel.Text = tostring(value)
        if config.Callback then config.Callback(value) end
    end

    valLabel.Focused:Connect(function()
        valLabel.TextColor3 = Theme.Text
    end)
    valLabel.FocusLost:Connect(function(enterPressed)
        valLabel.TextColor3 = Theme.SubText
        local num = tonumber(valLabel.Text)
        if num then
            setVal(math.floor(num + 0.5))
        else
            valLabel.Text = tostring(value)
        end
    end)

    local dragging = false

    local function update(inputX)
        local absPos = trackBg.AbsolutePosition.X
        local absSize = trackBg.AbsoluteSize.X
        local rel = math.clamp((inputX - absPos) / absSize, 0, 1)
        value = math.floor(min + (max - min) * rel + 0.5)
        local newPct = (value - min) / (max - min)
        fill.Size = UDim2.new(newPct, 0, 1, 0)
        knob.Position = UDim2.new(newPct, -6, 0.5, -6)
        valLabel.Text = tostring(value)
        if config.Callback then config.Callback(value) end
    end

    local inputBtn = Instance.new("TextButton")
    inputBtn.Text = ""
    inputBtn.BackgroundTransparency = 1
    inputBtn.Size = UDim2.new(1, 0, 0, 20)
    inputBtn.Position = UDim2.new(0, 0, 0, 24)
    inputBtn.ZIndex = 5
    inputBtn.Parent = holder

    inputBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    inputBtn.MouseButton1Click:Connect(function()
        local mouse = Players.LocalPlayer:GetMouse()
        update(mouse.X)
    end)

    local obj = {
        Set = function(_, val)
            value = math.clamp(val, min, max)
            local p = (value - min) / (max - min)
            fill.Size = UDim2.new(p, 0, 1, 0)
            knob.Position = UDim2.new(p, -6, 0.5, -6)
            valLabel.Text = tostring(value)
            if config.Callback then config.Callback(value) end
        end,
        Get = function() return value end,
    }
    local flagKey = config.Flag or (config.Text and (self._name .. "_" .. config.Text) or nil)
    if flagKey then
        self._lib._flags[flagKey] = { type = "Slider", obj = obj }
    end
    return obj
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: DROPDOWN
-- ═══════════════════════════════════════════════════
function Category:AddDropdown(config)
    config = config or {}
    local col, ci = self:_getColumn(config.Column)
    local order = self:_incOrder(ci)
    local options = config.Options or {}
    local selected = config.Default or (options[1] or "")
