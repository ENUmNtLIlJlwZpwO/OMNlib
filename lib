    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.Parent = holder

    -- Checkbox-style indicator
    local box = Instance.new("Frame")
    box.Name = "CheckBox"
    box.BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff
    box.Size = UDim2.new(0, 18, 0, 18)
    box.Position = UDim2.new(1, -28, 0.5, -9)
    box.Parent = holder
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)

    local boxStroke = Instance.new("UIStroke")
    boxStroke.Color = state and Theme.ToggleOn or Theme.Border
    boxStroke.Transparency = state and 0.3 or Theme.BorderTransp
    boxStroke.Thickness = 1
    boxStroke.Parent = box

    local check = Instance.new("TextLabel")
    check.Name = "Check"
    check.Text = "✓"
    check.Font = Theme.FontBold
    check.TextSize = 14
    check.TextColor3 = Theme.Background
    check.BackgroundTransparency = 1
    check.Size = UDim2.new(1, 0, 1, 0)
    check.TextTransparency = state and 0 or 1
    check.Parent = box

    local function updateToggle()
        state = not state
        tween(box, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.2)
        tween(boxStroke, {Color = state and Theme.ToggleOn or Theme.Border, Transparency = state and 0.3 or Theme.BorderTransp}, 0.2)
        tween(check, {TextTransparency = state and 0 or 1}, 0.2)
        if config.Callback then config.Callback(state) end
    end

    local clickBtn = Instance.new("TextButton")
    clickBtn.Text = ""
    clickBtn.BackgroundTransparency = 1
    clickBtn.Size = UDim2.new(1, 0, 1, 0)
    clickBtn.ZIndex = 5
    clickBtn.Parent = holder
    clickBtn.MouseButton1Click:Connect(updateToggle)

    local obj = {
        Set = function(_, val) if val ~= state then updateToggle() end end,
        Get = function() return state end,
    }
    local flagKey = config.Flag or (config.Text and (self._name .. "_" .. config.Text) or nil)
    if flagKey then
        self._lib._flags[flagKey] = { type = "Toggle", obj = obj }
    end
    return obj
end

