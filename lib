    opacityKnob.Size = UDim2.new(0, 12, 0, 12)
    opacityKnob.Position = UDim2.new(alpha, -6, 0.5, -6)
    opacityKnob.ZIndex = 2
    opacityKnob.Parent = opacityTrack
    Instance.new("UICorner", opacityKnob).CornerRadius = UDim.new(1, 0)
    local knobStroke = Instance.new("UIStroke")
    knobStroke.Color = Theme.Border
    knobStroke.Thickness = 1
    knobStroke.Parent = opacityKnob

    -- ── Update logic ──
    local function updateColor()
        color = Color3.fromHSV(h, s, v)
        preview.BackgroundColor3 = color
        svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        svCursor.Position = UDim2.new(s, -6, 1 - v, -6)
        hueCursor.Position = UDim2.new(0, -2, h, -2)
        opacityFill.Size = UDim2.new(alpha, 0, 1, 0)
        opacityFill.BackgroundColor3 = color
        opacityKnob.Position = UDim2.new(alpha, -6, 0.5, -6)
        opacityVal.Text = math.floor(alpha * 100 + 0.5) .. "%"
        if config.Callback then config.Callback(color, alpha) end
    end

    local draggingSV = false
    local draggingHue = false
    local draggingAlpha = false

    -- SV square input
    local svBtn = Instance.new("TextButton")
    svBtn.Text = ""
    svBtn.BackgroundTransparency = 1
    svBtn.Size = UDim2.new(1, 0, 1, 0)
    svBtn.ZIndex = 5
    svBtn.Parent = svFrame

    local function updateSV(inputX, inputY)
        local absPos = svFrame.AbsolutePosition
        local absSize = svFrame.AbsoluteSize
        s = math.clamp((inputX - absPos.X) / absSize.X, 0, 1)
        v = 1 - math.clamp((inputY - absPos.Y) / absSize.Y, 0, 1)
        updateColor()
    end

    svBtn.MouseButton1Down:Connect(function()
        draggingSV = true
        local mouse = Players.LocalPlayer:GetMouse()
        updateSV(mouse.X, mouse.Y)
    end)

    -- Hue bar input
    local hueBtn = Instance.new("TextButton")
    hueBtn.Text = ""
    hueBtn.BackgroundTransparency = 1
    hueBtn.Size = UDim2.new(1, 0, 1, 0)
    hueBtn.ZIndex = 5
    hueBtn.Parent = hueBar

    local function updateHue(inputY)
        local absPos = hueBar.AbsolutePosition.Y
        local absSize = hueBar.AbsoluteSize.Y
        h = math.clamp((inputY - absPos) / absSize, 0, 0.999)
        updateColor()
    end

    hueBtn.MouseButton1Down:Connect(function()
        draggingHue = true
        local mouse = Players.LocalPlayer:GetMouse()
        updateHue(mouse.Y)
    end)

    -- Opacity track input
    local opacityInputBtn = Instance.new("TextButton")
    opacityInputBtn.Text = ""
    opacityInputBtn.BackgroundTransparency = 1
    opacityInputBtn.Size = UDim2.new(1, 0, 1, 8)
    opacityInputBtn.Position = UDim2.new(0, 0, 0, -4)
    opacityInputBtn.ZIndex = 5
    opacityInputBtn.Parent = opacityTrack

    local function updateAlpha(inputX)
        local absPos = opacityTrack.AbsolutePosition.X
        local absSize = opacityTrack.AbsoluteSize.X
        alpha = math.clamp((inputX - absPos) / absSize, 0, 1)
        updateColor()
    end

    opacityInputBtn.MouseButton1Down:Connect(function()
        draggingAlpha = true
        local mouse = Players.LocalPlayer:GetMouse()
        updateAlpha(mouse.X)
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if draggingSV then
                updateSV(input.Position.X, input.Position.Y)
            elseif draggingHue then
                updateHue(input.Position.Y)
            elseif draggingAlpha then
                updateAlpha(input.Position.X)
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSV = false
            draggingHue = false
            draggingAlpha = false
        end
    end)

    -- Toggle open/close
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Text = ""
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Size = UDim2.new(1, 0, 0, 32)
    toggleBtn.ZIndex = 5
    toggleBtn.Parent = holder
    toggleBtn.MouseButton1Click:Connect(function()
        if open then
            open = false
            tween(holder, {Size = UDim2.new(1, 0, 0, 32)}, 0.2)
        else
            open = true
            tween(holder, {Size = UDim2.new(1, 0, 0, 32 + expandedH)}, 0.2)
        end
    end)

    local obj = {
        Set = function(_, c3, a)
            color = c3
            h, s, v = Color3.toHSV(c3)
            if a ~= nil then alpha = a end
            preview.BackgroundColor3 = c3
            updateColor()
        end,
        Get = function() return color, alpha end,
    }
    local flagKey = config.Flag or (config.Text and (self._name .. "_" .. config.Text) or nil)
    if flagKey then
        self._lib._flags[flagKey] = { type = "ColorPicker", obj = obj }
    end
    return obj
end

