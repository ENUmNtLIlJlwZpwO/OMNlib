--[[
    Glassmorphism UI Library for Roblox
    Style: Modern glass / frosted UI — Two-panel layout
    Left  = features list (per category)
    Right = category selector tabs
]]

local Library = {}
Library.__index = Library

local Category = {}
Category.__index = Category

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

-- ═══════════════════════════════════════════════════
--  THEME
-- ═══════════════════════════════════════════════════
local Theme = {
    Background      = Color3.fromRGB(18, 18, 24),
    Glass           = Color3.fromRGB(30, 30, 42),
    GlassHover      = Color3.fromRGB(40, 40, 55),
    Accent          = Color3.fromRGB(100, 120, 255),
    AccentHover     = Color3.fromRGB(130, 145, 255),
    Text            = Color3.fromRGB(230, 230, 240),
    SubText         = Color3.fromRGB(150, 150, 170),
    Border          = Color3.fromRGB(60, 60, 80),
    TabBg           = Color3.fromRGB(24, 24, 32),
    TabActive       = Color3.fromRGB(100, 120, 255),
    TabInactive     = Color3.fromRGB(38, 38, 52),
    ToggleOn        = Color3.fromRGB(100, 220, 140),
    ToggleOff       = Color3.fromRGB(80, 80, 100),
    Shadow          = Color3.fromRGB(0, 0, 0),

    Font            = Enum.Font.GothamMedium,
    FontBold        = Enum.Font.GothamBold,
    CornerRadius    = UDim.new(0, 8),
    CornerSmall     = UDim.new(0, 6),
    Transparency    = 0.25,
    BorderTransp    = 0.6,
    AnimSpeed       = 0.25,

    WindowWidth     = 560,
    WindowHeight    = 300,
    TabWidth        = 140,
}

-- ═══════════════════════════════════════════════════
--  HELPERS
-- ═══════════════════════════════════════════════════
local function tween(obj, props, duration)
    duration = duration or Theme.AnimSpeed
    local tw = TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

local function applyGlass(frame)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = Theme.CornerRadius
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Theme.Border
    stroke.Transparency = Theme.BorderTransp
    stroke.Thickness = 1
    stroke.Parent = frame
end

local function addShadow(parent)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://5554236805"
    shadow.ImageColor3 = Theme.Shadow
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(23, 23, 277, 277)
    shadow.Size = UDim2.new(1, 24, 1, 24)
    shadow.Position = UDim2.new(0, -12, 0, -12)
    shadow.ZIndex = parent.ZIndex - 1
    shadow.Parent = parent
end

-- ═══════════════════════════════════════════════════
--  WINDOW
-- ═══════════════════════════════════════════════════
function Library.new(title)
    local self = setmetatable({}, Library)

    local W = Theme.WindowWidth
    local H = Theme.WindowHeight
    local TW = Theme.TabWidth

    -- ScreenGui
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "GlassUI"
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

    -- Main Frame
    self.Main = Instance.new("Frame")
    self.Main.Name = "Main"
    self.Main.BackgroundColor3 = Theme.Background
    self.Main.BackgroundTransparency = Theme.Transparency
    self.Main.Size = UDim2.new(0, W, 0, 0)
    self.Main.Position = UDim2.new(0.5, -W / 2, 0.5, 0)
    self.Main.AnchorPoint = Vector2.new(0, 0.5)
    self.Main.ClipsDescendants = true
    self.Main.Parent = self.ScreenGui
    applyGlass(self.Main)
    addShadow(self.Main)

    -- ─── Title Bar ───
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.BackgroundColor3 = Theme.Glass
    titleBar.BackgroundTransparency = 0.3
    titleBar.Size = UDim2.new(1, 0, 0, 38)
    titleBar.Parent = self.Main
    Instance.new("UICorner", titleBar).CornerRadius = Theme.CornerRadius

    -- Accent line
    local accent = Instance.new("Frame")
    accent.Name = "AccentLine"
    accent.BackgroundColor3 = Theme.Accent
    accent.Size = UDim2.new(0, 40, 0, 3)
    accent.Position = UDim2.new(0, 16, 1, -1)
    accent.BorderSizePixel = 0
    accent.Parent = titleBar
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 2)

    -- Title text
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Text = title or "Glass UI"
    titleLabel.Font = Theme.FontBold
    titleLabel.TextSize = 15
    titleLabel.TextColor3 = Theme.Text
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -80, 1, 0)
    titleLabel.Position = UDim2.new(0, 16, 0, 0)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = titleBar

    -- Close Button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name = "Close"
    closeBtn.Text = "×"
    closeBtn.Font = Theme.Font
    closeBtn.TextSize = 22
    closeBtn.TextColor3 = Theme.SubText
    closeBtn.BackgroundTransparency = 1
    closeBtn.Size = UDim2.new(0, 38, 0, 38)
    closeBtn.Position = UDim2.new(1, -38, 0, 0)
    closeBtn.Parent = titleBar

    closeBtn.MouseButton1Click:Connect(function()
        tween(self.Main, {Size = UDim2.new(0, W, 0, 0)}, 0.35)
        task.wait(0.35)
        self.ScreenGui:Destroy()
    end)
    closeBtn.MouseEnter:Connect(function() tween(closeBtn, {TextColor3 = Color3.fromRGB(255, 80, 80)}, 0.15) end)
    closeBtn.MouseLeave:Connect(function() tween(closeBtn, {TextColor3 = Theme.SubText}, 0.15) end)

    -- Minimize Button
    local minBtn = Instance.new("TextButton")
    minBtn.Name = "Minimize"
    minBtn.Text = "–"
    minBtn.Font = Theme.Font
    minBtn.TextSize = 20
    minBtn.TextColor3 = Theme.SubText
    minBtn.BackgroundTransparency = 1
    minBtn.Size = UDim2.new(0, 38, 0, 38)
    minBtn.Position = UDim2.new(1, -72, 0, 0)
    minBtn.Parent = titleBar

    self._minimized = false
    self._expandedSize = nil

    minBtn.MouseButton1Click:Connect(function()
        if self._minimized then
            tween(self.Main, {Size = self._expandedSize}, 0.3)
            self._minimized = false
        else
            self._expandedSize = self.Main.Size
            tween(self.Main, {Size = UDim2.new(0, W, 0, 38)}, 0.3)
            self._minimized = true
        end
    end)
    minBtn.MouseEnter:Connect(function() tween(minBtn, {TextColor3 = Theme.Accent}, 0.15) end)
    minBtn.MouseLeave:Connect(function() tween(minBtn, {TextColor3 = Theme.SubText}, 0.15) end)

    -- ─── Drag ───
    local dragging, dragInput, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- ═══════════════════════════════════════════════
    --  BODY: two-panel layout
    -- ═══════════════════════════════════════════════
    local body = Instance.new("Frame")
    body.Name = "Body"
    body.BackgroundTransparency = 1
    body.Size = UDim2.new(1, 0, 1, -42)
    body.Position = UDim2.new(0, 0, 0, 42)
    body.ClipsDescendants = true
    body.Parent = self.Main

    -- ─── LEFT: Category tabs ───
    local tabPanel = Instance.new("Frame")
    tabPanel.Name = "TabPanel"
    tabPanel.BackgroundColor3 = Theme.TabBg
    tabPanel.BackgroundTransparency = 0.3
    tabPanel.Size = UDim2.new(0, TW, 1, 0)
    tabPanel.Position = UDim2.new(0, 0, 0, 0)
    tabPanel.Parent = body
    Instance.new("UICorner", tabPanel).CornerRadius = Theme.CornerSmall

    local tabStroke = Instance.new("UIStroke")
    tabStroke.Color = Theme.Border
    tabStroke.Transparency = Theme.BorderTransp
    tabStroke.Thickness = 1
    tabStroke.Parent = tabPanel

    -- Tab list layout
    local tabScroll = Instance.new("ScrollingFrame")
    tabScroll.Name = "TabScroll"
    tabScroll.BackgroundTransparency = 1
    tabScroll.Size = UDim2.new(1, 0, 1, 0)
    tabScroll.ScrollBarThickness = 0
    tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabScroll.Parent = tabPanel

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 4)
    tabLayout.Parent = tabScroll

    local tabPadding = Instance.new("UIPadding")
    tabPadding.PaddingLeft = UDim.new(0, 8)
    tabPadding.PaddingRight = UDim.new(0, 8)
    tabPadding.PaddingTop = UDim.new(0, 8)
    tabPadding.PaddingBottom = UDim.new(0, 8)
    tabPadding.Parent = tabScroll

    -- Vertical separator line
    local vSep = Instance.new("Frame")
    vSep.Name = "VSeparator"
    vSep.BackgroundColor3 = Theme.Border
    vSep.BackgroundTransparency = 0.4
    vSep.Size = UDim2.new(0, 1, 1, -8)
    vSep.Position = UDim2.new(0, TW, 0, 4)
    vSep.BorderSizePixel = 0
    vSep.Parent = body

    -- ─── RIGHT: Content area (per-category frames) ───
    local contentArea = Instance.new("Frame")
    contentArea.Name = "ContentArea"
    contentArea.BackgroundTransparency = 1
    contentArea.Size = UDim2.new(1, -TW - 1, 1, 0)
    contentArea.Position = UDim2.new(0, TW + 1, 0, 0)
    contentArea.ClipsDescendants = true
    contentArea.Parent = body

    -- State
    self._categories = {}
    self._tabButtons = {}
    self._activeCategory = nil
    self._tabScroll = tabScroll
    self._contentArea = contentArea
    self._tabOrder = 0

    -- Open animation
    task.defer(function()
        task.wait(0.05)
        tween(self.Main, {Size = UDim2.new(0, W, 0, H)}, 0.4)
    end)

    return self
end

-- ═══════════════════════════════════════════════════
--  ADD CATEGORY (creates a tab + content page)
-- ═══════════════════════════════════════════════════
function Library:AddCategory(name, icon)
    self._tabOrder = self._tabOrder + 1
    local displayText = icon and (icon .. "  " .. name) or name

    -- Content page (scrolling frame, hidden by default)
    local page = Instance.new("ScrollingFrame")
    page.Name = "Page_" .. name
    page.BackgroundTransparency = 1
    page.Size = UDim2.new(1, 0, 1, 0)
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Theme.Accent
    page.ScrollBarImageTransparency = 0.4
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.ClipsDescendants = true
    page.Visible = false
    page.Parent = self._contentArea

    local pageLayout = Instance.new("UIListLayout")
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.Parent = page

    local pagePad = Instance.new("UIPadding")
    pagePad.PaddingLeft = UDim.new(0, 12)
    pagePad.PaddingRight = UDim.new(0, 12)
    pagePad.PaddingTop = UDim.new(0, 8)
    pagePad.PaddingBottom = UDim.new(0, 10)
    pagePad.Parent = page

    -- Tab button (right panel)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Name = "Tab_" .. name
    tabBtn.Text = displayText
    tabBtn.Font = Theme.Font
    tabBtn.TextSize = 13
    tabBtn.TextColor3 = Theme.SubText
    tabBtn.BackgroundColor3 = Theme.TabInactive
    tabBtn.BackgroundTransparency = 0.3
    tabBtn.Size = UDim2.new(1, 0, 0, 32)
    tabBtn.AutoButtonColor = false
    tabBtn.LayoutOrder = self._tabOrder
    tabBtn.Parent = self._tabScroll
    Instance.new("UICorner", tabBtn).CornerRadius = Theme.CornerSmall

    -- Store references
    self._categories[name] = { page = page, tabBtn = tabBtn, order = 0 }
    table.insert(self._tabButtons, { name = name, btn = tabBtn })

    -- Switch logic
    local libSelf = self
    local function switchTo()
        -- Deactivate all
        for catName, cat in pairs(libSelf._categories) do
            cat.page.Visible = false
            tween(cat.tabBtn, {
                BackgroundColor3 = Theme.TabInactive,
                BackgroundTransparency = 0.3,
                TextColor3 = Theme.SubText
            }, 0.2)
        end
        -- Activate this one
        page.Visible = true
        tween(tabBtn, {
            BackgroundColor3 = Theme.TabActive,
            BackgroundTransparency = 0.15,
            TextColor3 = Theme.Text
        }, 0.2)
        libSelf._activeCategory = name
    end

    tabBtn.MouseButton1Click:Connect(switchTo)

    tabBtn.MouseEnter:Connect(function()
        if libSelf._activeCategory ~= name then
            tween(tabBtn, {BackgroundTransparency = 0.15, TextColor3 = Theme.Text}, 0.15)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if libSelf._activeCategory ~= name then
            tween(tabBtn, {BackgroundTransparency = 0.3, TextColor3 = Theme.SubText}, 0.15)
        end
    end)

    -- Auto-select first category
    if self._tabOrder == 1 then
        switchTo()
    end

    -- Return a Category object to chain :AddButton, :AddToggle, etc.
    local cat = setmetatable({}, Category)
    cat._lib = self
    cat._name = name
    cat._page = page
    cat._data = self._categories[name]
    return cat
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: BUTTON
-- ═══════════════════════════════════════════════════
function Category:AddButton(config)
    config = config or {}
    self._data.order = self._data.order + 1

    local btn = Instance.new("TextButton")
    btn.Name = config.Name or "Button"
    btn.Text = config.Text or "Button"
    btn.Font = Theme.Font
    btn.TextSize = 14
    btn.TextColor3 = Theme.Text
    btn.BackgroundColor3 = Theme.Glass
    btn.BackgroundTransparency = Theme.Transparency
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.LayoutOrder = self._data.order
    btn.AutoButtonColor = false
    btn.Parent = self._page
    applyGlass(btn)

    btn.MouseEnter:Connect(function()
        tween(btn, {BackgroundColor3 = Theme.Accent, BackgroundTransparency = 0.15}, 0.2)
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, {BackgroundColor3 = Theme.Glass, BackgroundTransparency = Theme.Transparency}, 0.2)
    end)
    btn.MouseButton1Click:Connect(function()
        tween(btn, {BackgroundTransparency = 0}, 0.05)
        task.wait(0.05)
        tween(btn, {BackgroundTransparency = 0.15}, 0.15)
        if config.Callback then config.Callback() end
    end)

    return btn
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: TOGGLE
-- ═══════════════════════════════════════════════════
function Category:AddToggle(config)
    config = config or {}
    self._data.order = self._data.order + 1
    local state = config.Default or false

    local holder = Instance.new("Frame")
    holder.Name = config.Name or "Toggle"
    holder.BackgroundColor3 = Theme.Glass
    holder.BackgroundTransparency = Theme.Transparency
    holder.Size = UDim2.new(1, 0, 0, 34)
    holder.LayoutOrder = self._data.order
    holder.Parent = self._page
    applyGlass(holder)

    local label = Instance.new("TextLabel")
    label.Text = config.Text or "Toggle"
    label.Font = Theme.Font
    label.TextSize = 14
    label.TextColor3 = Theme.Text
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -60, 1, 0)
    label.Position = UDim2.new(0, 12, 0, 0)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = holder

    local track = Instance.new("Frame")
    track.Name = "Track"
    track.BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff
    track.Size = UDim2.new(0, 36, 0, 18)
    track.Position = UDim2.new(1, -48, 0.5, -9)
    track.Parent = holder
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function updateToggle()
        state = not state
        tween(track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.2)
        tween(knob, {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.2)
        if config.Callback then config.Callback(state) end
    end

    local clickBtn = Instance.new("TextButton")
    clickBtn.Text = ""
    clickBtn.BackgroundTransparency = 1
    clickBtn.Size = UDim2.new(1, 0, 1, 0)
    clickBtn.ZIndex = 5
    clickBtn.Parent = holder
    clickBtn.MouseButton1Click:Connect(updateToggle)

    return {
        Set = function(_, val) if val ~= state then updateToggle() end end,
        Get = function() return state end,
    }
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: LABEL
-- ═══════════════════════════════════════════════════
function Category:AddLabel(text)
    self._data.order = self._data.order + 1

    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Text = text or "Label"
    label.Font = Theme.Font
    label.TextSize = 13
    label.TextColor3 = Theme.SubText
    label.BackgroundTransparency = 1
