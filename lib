function Library:_toggleRemoteSpy()
    if not self._remoteSpy then
        self:_createRemoteSpy()
        return
    end

    local spy = self._remoteSpy
    if spy.open then
        spy.open = false
        tween(spy.frame, {Size = UDim2.new(0, spy.frame.Size.X.Offset, 0, 0)}, 0.3)
        task.delay(0.35, function()
            if not spy.open then spy.frame.Visible = false end
        end)
    else
        spy.open = true
        spy.frame.Visible = true
        tween(spy.frame, {Size = UDim2.new(0, spy.targetW or spy.frame.Size.X.Offset, 0, spy.targetH)}, 0.3)
    end
end

