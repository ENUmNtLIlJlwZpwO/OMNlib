--[[
    Glassmorphism UI Library for Roblox
    Layout: Horizontal category tabs on top, 3-column feature grid below
]]

local Library = {}
Library.__index = Library

local Category = {}
Category.__index = Category

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LogService = game:GetService("LogService")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")

-- ═══════════════════════════════════════════════════
--  THEME
-- ═══════════════════════════════════════════════════
local Theme = {
    Background      = Color3.fromRGB(20, 20, 22),
    Glass           = Color3.fromRGB(32, 32, 36),
    GlassHover      = Color3.fromRGB(48, 48, 54),
    Accent          = Color3.fromRGB(155, 155, 165),
    AccentHover     = Color3.fromRGB(180, 180, 190),
    Text            = Color3.fromRGB(220, 220, 225),
    SubText         = Color3.fromRGB(120, 120, 130),
    Border          = Color3.fromRGB(55, 55, 60),
    TabBg           = Color3.fromRGB(25, 25, 28),
    TabActive       = Color3.fromRGB(70, 70, 78),
    TabInactive     = Color3.fromRGB(36, 36, 40),
    ToggleOn        = Color3.fromRGB(175, 175, 185),
    ToggleOff       = Color3.fromRGB(50, 50, 55),
    Shadow          = Color3.fromRGB(0, 0, 0),

    Font            = Enum.Font.GothamMedium,
    FontBold        = Enum.Font.GothamBold,
    CornerRadius    = UDim.new(0, 8),
    CornerSmall     = UDim.new(0, 6),
    Transparency    = 0.25,
    BorderTransp    = 0.6,
    AnimSpeed       = 0.25,

    WindowWidth     = 620,
    WindowHeight    = 340,
    TitleBarH       = 38,
    TabBarH         = 34,
    Columns         = 3,
    ColGap          = 4,
    ColPadX         = 5,
    ColPadY         = 5,
}

-- ═══════════════════════════════════════════════════
--  HELPERS
-- ═══════════════════════════════════════════════════
local function tween(obj, props, duration)
    duration = duration or Theme.AnimSpeed
    local tw = TweenService:Create(obj, TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

local function applyGlass(frame)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = Theme.CornerRadius
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Theme.Border
    stroke.Transparency = Theme.BorderTransp
    stroke.Thickness = 1
    stroke.Parent = frame
end

local function applySmallCorner(frame)
    Instance.new("UICorner", frame).CornerRadius = Theme.CornerSmall
end

local function addShadow(parent)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://5554236805"
    shadow.ImageColor3 = Theme.Shadow
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(23, 23, 277, 277)
    shadow.Size = UDim2.new(1, 24, 1, 24)
    shadow.Position = UDim2.new(0, -12, 0, -12)
    shadow.ZIndex = parent.ZIndex - 1
    shadow.Parent = parent
end

-- Helper: build a scrolling column
local function makeColumn(parent, index, totalCols, gap, padX, padY)
    local colWidth = (1 / totalCols)
    local offsetX = (index - 1) * gap

    local col = Instance.new("ScrollingFrame")
    col.Name = "Column" .. index
    col.BackgroundTransparency = 1
    col.Size = UDim2.new(colWidth, -gap, 1, 0)
    col.Position = UDim2.new(colWidth * (index - 1), index == 1 and 0 or (gap / 2), 0, 0)
    col.ScrollBarThickness = 4
    col.ScrollBarImageColor3 = Theme.Accent
    col.ScrollBarImageTransparency = 0.2
    col.TopImage = ""
    col.MidImage = ""
    col.BottomImage = ""
    col.CanvasSize = UDim2.new(0, 0, 0, 0)
    col.AutomaticCanvasSize = Enum.AutomaticSize.Y
    col.ScrollingDirection = Enum.ScrollingDirection.Y
    col.ClipsDescendants = true
    col.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 5)
    layout.Parent = col

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0, padX)
    pad.PaddingRight = UDim.new(0, padX)
    pad.PaddingTop = UDim.new(0, padY)
    pad.PaddingBottom = UDim.new(0, padY)
    pad.Parent = col

    return col
end

-- ═══════════════════════════════════════════════════
--  BOOT ANIMATION
-- ═══════════════════════════════════════════════════
local function playBootAnimation(screenGui, titleText)
    -- ── Dedicated fullscreen GUI for overlay ──
    local bootGui = Instance.new("ScreenGui")
    bootGui.Name = "BootScreen"
    bootGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    bootGui.IgnoreGuiInset = true
    bootGui.ResetOnSpawn = false
    bootGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

    -- ── Dark overlay ──
    local overlay = Instance.new("Frame")
    overlay.Name = "BootOverlay"
    overlay.BackgroundColor3 = Color3.fromRGB(6, 6, 8)
    overlay.BackgroundTransparency = 1
    overlay.Size = UDim2.new(1, 0, 1, 0)
    overlay.ZIndex = 50
    overlay.Parent = bootGui

    tween(overlay, {BackgroundTransparency = 0.25}, 0.35)
    task.wait(0.3)

    -- ── Glass card ──
    local card = Instance.new("Frame")
    card.Name = "BootCard"
    card.BackgroundColor3 = Theme.Glass
    card.BackgroundTransparency = 0.1
    card.Size = UDim2.new(0, 0, 0, 0)
    card.Position = UDim2.new(0.5, 0, 0.5, 0)
    card.AnchorPoint = Vector2.new(0.5, 0.5)
    card.ClipsDescendants = true
    card.ZIndex = 51
    card.Parent = bootGui
    Instance.new("UICorner", card).CornerRadius = Theme.CornerRadius

    local cardStroke = Instance.new("UIStroke")
    cardStroke.Color = Theme.Border
    cardStroke.Transparency = 0.4
    cardStroke.Thickness = 1
    cardStroke.Parent = card

    tween(card, {Size = UDim2.new(0, 260, 0, 110)}, 0.45)
    task.wait(0.5)

    -- ── Title (typewriter) ──
    local bootTitle = Instance.new("TextLabel")
    bootTitle.Name = "BootTitle"
    bootTitle.Text = ""
    bootTitle.Font = Theme.FontBold
    bootTitle.TextSize = 18
    bootTitle.TextColor3 = Theme.Text
    bootTitle.BackgroundTransparency = 1
    bootTitle.Size = UDim2.new(1, 0, 0, 24)
    bootTitle.Position = UDim2.new(0, 0, 0, 18)
    bootTitle.ZIndex = 52
    bootTitle.Parent = card

    local fullTitle = titleText or "Glass UI"
    for i = 1, #fullTitle do
        bootTitle.Text = string.sub(fullTitle, 1, i)
        task.wait(0.045)
    end
    task.wait(0.2)

    -- ── Accent scan line sweep ──
    local scanLine = Instance.new("Frame")
    scanLine.Name = "ScanLine"
    scanLine.BackgroundColor3 = Theme.Accent
    scanLine.Size = UDim2.new(0, 50, 1, 0)
    scanLine.Position = UDim2.new(0, -50, 0, 0)
    scanLine.ZIndex = 53
    scanLine.Parent = card

    local scanGrad = Instance.new("UIGradient")
    scanGrad.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(0.5, 0.65),
        NumberSequenceKeypoint.new(1, 0.15),
    })
    scanGrad.Parent = scanLine

    tween(scanLine, {Position = UDim2.new(1, 10, 0, 0)}, 0.6)
    task.wait(0.65)
    scanLine:Destroy()

    -- ── Progress bar ──
    local track = Instance.new("Frame")
    track.Name = "BootTrack"
    track.BackgroundColor3 = Theme.ToggleOff
    track.Size = UDim2.new(0.6, 0, 0, 2)
    track.Position = UDim2.new(0.2, 0, 0, 58)
    track.ZIndex = 52
    track.Parent = card
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Name = "BootFill"
    fill.BackgroundColor3 = Theme.Accent
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.ZIndex = 53
    fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    -- ── Status text ──
    local status = Instance.new("TextLabel")
    status.Name = "BootStatus"
    status.Text = "Initializing..."
    status.Font = Theme.Font
    status.TextSize = 10
    status.TextColor3 = Theme.SubText
    status.BackgroundTransparency = 1
    status.Size = UDim2.new(1, 0, 0, 14)
    status.Position = UDim2.new(0, 0, 0, 68)
    status.ZIndex = 52
    status.Parent = card

    -- ── Fill stages (longer pauses) ──
    tween(fill, {Size = UDim2.new(0.2, 0, 1, 0)}, 0.35)
    task.wait(0.45)

    status.Text = "Loading modules..."
    tween(fill, {Size = UDim2.new(0.45, 0, 1, 0)}, 0.35)
    task.wait(0.5)

    status.Text = "Verifying environment..."
    tween(fill, {Size = UDim2.new(0.65, 0, 1, 0)}, 0.3)
    task.wait(0.45)

    status.Text = "Applying theme..."
    tween(fill, {Size = UDim2.new(0.85, 0, 1, 0)}, 0.3)
    task.wait(0.4)

    status.Text = "Ready"
    tween(status, {TextColor3 = Theme.Accent}, 0.2)
    tween(fill, {Size = UDim2.new(1, 0, 1, 0)}, 0.2)
    task.wait(0.5)

    -- ── Fade out card only (keep overlay for changelog) ──
    tween(card, {BackgroundTransparency = 1, Size = UDim2.new(0, 290, 0, 120)}, 0.35)
    tween(cardStroke, {Transparency = 1}, 0.35)
    tween(bootTitle, {TextTransparency = 1}, 0.3)
    tween(status, {TextTransparency = 1}, 0.3)
    tween(track, {BackgroundTransparency = 1}, 0.3)
    tween(fill, {BackgroundTransparency = 1}, 0.3)
    task.wait(0.4)

    card:Destroy()
    return bootGui, overlay
end

-- ═══════════════════════════════════════════════════
--  WINDOW
-- ═══════════════════════════════════════════════════
function Library.new(title)
    local self = setmetatable({}, Library)

    local W = Theme.WindowWidth
    local H = Theme.WindowHeight

    -- ScreenGui
    self.ScreenGui = Instance.new("ScreenGui")
    self.ScreenGui.Name = "GlassUI"
    self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.ScreenGui.ResetOnSpawn = false
    self.ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

    -- Main Frame (hidden until boot finishes)
    self.Main = Instance.new("Frame")
    self.Main.Name = "Main"
    self.Main.BackgroundColor3 = Theme.Background
    self.Main.BackgroundTransparency = Theme.Transparency
    self.Main.Size = UDim2.new(0, W, 0, 0)
    self.Main.Position = UDim2.new(0.5, -W / 2, 0.5, 0)
    self.Main.AnchorPoint = Vector2.new(0, 0.5)
    self.Main.ClipsDescendants = true
    self.Main.Visible = false
    self.Main.Parent = self.ScreenGui
    applyGlass(self.Main)
    addShadow(self.Main)

    -- ─── Title Bar ───
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.BackgroundColor3 = Theme.Glass
    titleBar.BackgroundTransparency = 0.3
    titleBar.Size = UDim2.new(1, 0, 0, Theme.TitleBarH)
    titleBar.Parent = self.Main
    Instance.new("UICorner", titleBar).CornerRadius = Theme.CornerRadius

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.Text = title or "Glass UI"
    titleLabel.Font = Theme.FontBold
    titleLabel.TextSize = 15
    titleLabel.TextColor3 = Theme.Text
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, -80, 1, 0)
    titleLabel.Position = UDim2.new(0, 16, 0, 0)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = titleBar

    -- Close
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name = "Close"
    closeBtn.Text = "×"
    closeBtn.Font = Theme.Font
    closeBtn.TextSize = 22
    closeBtn.TextColor3 = Theme.SubText
    closeBtn.BackgroundTransparency = 1
    closeBtn.Size = UDim2.new(0, 38, 0, Theme.TitleBarH)
    closeBtn.Position = UDim2.new(1, -38, 0, 0)
    closeBtn.Parent = titleBar
    closeBtn.MouseButton1Click:Connect(function()
        tween(self.Main, {Size = UDim2.new(0, W, 0, 0)}, 0.35)
        task.wait(0.35)
        self.ScreenGui:Destroy()
    end)
    closeBtn.MouseEnter:Connect(function() tween(closeBtn, {TextColor3 = Color3.fromRGB(255, 80, 80)}, 0.15) end)
    closeBtn.MouseLeave:Connect(function() tween(closeBtn, {TextColor3 = Theme.SubText}, 0.15) end)

    -- Minimize
    local minBtn = Instance.new("TextButton")
    minBtn.Name = "Minimize"
    minBtn.Text = "–"
    minBtn.Font = Theme.Font
    minBtn.TextSize = 20
    minBtn.TextColor3 = Theme.SubText
    minBtn.BackgroundTransparency = 1
    minBtn.Size = UDim2.new(0, 38, 0, Theme.TitleBarH)
    minBtn.Position = UDim2.new(1, -72, 0, 0)
    minBtn.Parent = titleBar

    self._minimized = false
    self._expandedSize = nil
    minBtn.MouseButton1Click:Connect(function()
        if self._minimized then
            tween(self.Main, {Size = self._expandedSize}, 0.3)
            self._minimized = false
        else
            self._expandedSize = self.Main.Size
            tween(self.Main, {Size = UDim2.new(0, W, 0, Theme.TitleBarH)}, 0.3)
            self._minimized = true
        end
    end)
    minBtn.MouseEnter:Connect(function() tween(minBtn, {TextColor3 = Theme.Accent}, 0.15) end)
    minBtn.MouseLeave:Connect(function() tween(minBtn, {TextColor3 = Theme.SubText}, 0.15) end)

    -- ─── Drag ───
    local dragging, dragInput, dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.Main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            self.Main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    -- ═══════════════════════════════════════════════
    --  TAB BAR (horizontal, below title)
    -- ═══════════════════════════════════════════════
    local topOffset = Theme.TitleBarH + 4

    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundColor3 = Theme.TabBg
    tabBar.BackgroundTransparency = 0.4
    tabBar.Size = UDim2.new(1, -16, 0, Theme.TabBarH)
    tabBar.Position = UDim2.new(0, 8, 0, topOffset)
    tabBar.Parent = self.Main
    applySmallCorner(tabBar)

    local tabBarStroke = Instance.new("UIStroke")
    tabBarStroke.Color = Theme.Border
    tabBarStroke.Transparency = Theme.BorderTransp
    tabBarStroke.Thickness = 1
    tabBarStroke.Parent = tabBar

    -- Horizontal scroll for tabs
    local tabScroll = Instance.new("ScrollingFrame")
    tabScroll.Name = "TabScroll"
    tabScroll.BackgroundTransparency = 1
    tabScroll.Size = UDim2.new(1, 0, 1, 0)
    tabScroll.ScrollBarThickness = 0
    tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
    tabScroll.ScrollingDirection = Enum.ScrollingDirection.X
    tabScroll.Parent = tabBar

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 6)
    tabLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    tabLayout.Parent = tabScroll

    local tabPad = Instance.new("UIPadding")
    tabPad.PaddingLeft = UDim.new(0, 8)
    tabPad.PaddingRight = UDim.new(0, 8)
    tabPad.Parent = tabScroll

    -- ═══════════════════════════════════════════════
    --  CONTENT AREA (below tab bar — holds per-category 3-col pages)
    -- ═══════════════════════════════════════════════
    local contentTop = topOffset + Theme.TabBarH + 4

    local contentArea = Instance.new("Frame")
    contentArea.Name = "ContentArea"
    contentArea.BackgroundTransparency = 1
    contentArea.Size = UDim2.new(1, -16, 1, -contentTop - 6)
    contentArea.Position = UDim2.new(0, 8, 0, contentTop)
    contentArea.ClipsDescendants = true
    contentArea.Parent = self.Main

    -- State
    self._categories = {}
    self._tabButtons = {}
    self._activeCategory = nil
    self._tabScroll = tabScroll
    self._contentArea = contentArea
    self._tabOrder = 0
    self._flags = {}
    self._configFolder = "GlassUI_Configs"

    -- Boot sequence + open animation
    self._bootDone = false
    task.defer(function()
        local bootGui, bootOverlay = playBootAnimation(self.ScreenGui, title or "Glass UI")
        self._overlayGui = bootGui
        self._overlayFrame = bootOverlay
        -- Show main frame and animate open
        self.Main.Visible = true
        local mainStroke = self.Main:FindFirstChildOfClass("UIStroke")
        if mainStroke then
            mainStroke.Color = Theme.Accent
            mainStroke.Transparency = 0
        end
        tween(self.Main, {Size = UDim2.new(0, W, 0, H)}, 0.4)
        task.wait(0.45)
        if mainStroke then
            tween(mainStroke, {Color = Theme.Border, Transparency = Theme.BorderTransp}, 0.5)
        end
        -- Show watermark after boot
        self._bootDone = true
        if self._watermark then
            self._watermark.Visible = true
        end
        -- Fire OnReady callbacks
        if self._onReadyCallbacks then
            for _, cb in ipairs(self._onReadyCallbacks) do
                task.spawn(cb)
            end
        end
        -- If no changelog was shown, fade out overlay
        task.wait(0.3)
        if self._overlayGui and not self._changelogOpen then
            tween(self._overlayFrame, {BackgroundTransparency = 1}, 0.35)
            task.wait(0.4)
            if self._overlayGui and not self._changelogOpen then
                self._overlayGui:Destroy()
                self._overlayGui = nil
                self._overlayFrame = nil
            end
        end
    end)

    return self
end

function Library:OnReady(callback)
    if self._bootDone then
        task.spawn(callback)
    else
        if not self._onReadyCallbacks then self._onReadyCallbacks = {} end
        table.insert(self._onReadyCallbacks, callback)
    end
end

-- ═══════════════════════════════════════════════════
--  ADD CATEGORY
-- ═══════════════════════════════════════════════════
function Library:AddCategory(name, icon, opts)
    opts = opts or {}
    self._tabOrder = self._tabOrder + 1

    -- Page frame (holds 3 columns, hidden by default)
    local page = Instance.new("Frame")
    page.Name = "Page_" .. name
    page.BackgroundTransparency = 1
    page.Size = UDim2.new(1, 0, 1, 0)
    page.Visible = false
    page.ClipsDescendants = true
    page.Parent = self._contentArea

    -- Groups transparency for fade transitions
    local pageGroup = Instance.new("CanvasGroup")
    pageGroup.Name = "PageGroup"
    pageGroup.BackgroundTransparency = 1
    pageGroup.Size = UDim2.new(1, 0, 1, 0)
    pageGroup.GroupTransparency = 1
    pageGroup.Parent = page

    -- Build 3 columns
    local cols = {}
    for i = 1, Theme.Columns do
        cols[i] = makeColumn(pageGroup, i, Theme.Columns, Theme.ColGap, Theme.ColPadX, Theme.ColPadY)
    end

    -- Tab button (horizontal bar)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Name = "Tab_" .. name
    tabBtn.Text = ""
    tabBtn.Font = Theme.Font
    tabBtn.TextSize = 13
    tabBtn.TextColor3 = Theme.SubText
    tabBtn.BackgroundColor3 = Theme.TabInactive
    tabBtn.BackgroundTransparency = 0.3
    tabBtn.Size = UDim2.new(0, 0, 0, 26)
    tabBtn.AutomaticSize = Enum.AutomaticSize.X
    tabBtn.AutoButtonColor = false
    tabBtn.LayoutOrder = opts.LayoutOrder or self._tabOrder
    tabBtn.Parent = self._tabScroll
    applySmallCorner(tabBtn)

    local btnPad = Instance.new("UIPadding")
    btnPad.PaddingLeft = UDim.new(0, opts.IconOnly and 6 or 8)
    btnPad.PaddingRight = UDim.new(0, opts.IconOnly and 6 or 10)
    btnPad.Parent = tabBtn

    local tabInnerLayout = Instance.new("UIListLayout")
    tabInnerLayout.FillDirection = Enum.FillDirection.Horizontal
    tabInnerLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    tabInnerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabInnerLayout.Padding = UDim.new(0, 6)
    tabInnerLayout.Parent = tabBtn

    if icon then
        local tabIcon = Instance.new("ImageLabel")
        tabIcon.Name = "Icon"
        tabIcon.BackgroundTransparency = 1
        tabIcon.Image = icon
        tabIcon.ImageColor3 = Theme.SubText
        tabIcon.Size = UDim2.new(0, 14, 0, 14)
        tabIcon.LayoutOrder = 1
        tabIcon.Parent = tabBtn
    end

    local tabText = nil
    if not opts.IconOnly then
        tabText = Instance.new("TextLabel")
        tabText.Name = "TabLabel"
        tabText.Text = name
        tabText.Font = Theme.Font
        tabText.TextSize = 13
        tabText.TextColor3 = Theme.SubText
        tabText.BackgroundTransparency = 1
        tabText.Size = UDim2.new(0, 0, 1, 0)
        tabText.AutomaticSize = Enum.AutomaticSize.X
        tabText.LayoutOrder = 2
        tabText.Parent = tabBtn
    end

    -- Store
    self._categories[name] = {
        page = page,
        tabBtn = tabBtn,
        cols = cols,
        colOrders = {0, 0, 0},
    }
    table.insert(self._tabButtons, { name = name, btn = tabBtn })

    -- Switch logic
    local libSelf = self
    local function switchTo()
        if libSelf._activeCategory == name then return end

        -- Fade out old page
        local oldName = libSelf._activeCategory
        if oldName and libSelf._categories[oldName] then
            local oldPage = libSelf._categories[oldName].page
            local oldGroup = oldPage:FindFirstChild("PageGroup")
            if oldGroup then
                tween(oldGroup, {GroupTransparency = 1}, 0.15)
            end
            task.delay(0.15, function()
                if libSelf._activeCategory ~= oldName then
                    oldPage.Visible = false
                end
            end)
        end

        -- Deactivate all tabs
        for catName, cat in pairs(libSelf._categories) do
            tween(cat.tabBtn, {
                BackgroundColor3 = Theme.TabInactive,
                BackgroundTransparency = 0.3,
            }, 0.2)
            local lbl = cat.tabBtn:FindFirstChild("TabLabel")
            if lbl then tween(lbl, {TextColor3 = Theme.SubText}, 0.2) end
            local ico = cat.tabBtn:FindFirstChild("Icon")
            if ico then tween(ico, {ImageColor3 = Theme.SubText}, 0.2) end
        end

        -- Activate new tab
        libSelf._activeCategory = name
        page.Visible = true
        local newGroup = page:FindFirstChild("PageGroup")
        if newGroup then
            newGroup.GroupTransparency = 1
            tween(newGroup, {GroupTransparency = 0}, 0.2)
        end
        tween(tabBtn, {
            BackgroundColor3 = Theme.TabActive,
            BackgroundTransparency = 0.1,
        }, 0.2)
        if tabText then tween(tabText, {TextColor3 = Theme.Text}, 0.2) end
        local myIcon = tabBtn:FindFirstChild("Icon")
        if myIcon then tween(myIcon, {ImageColor3 = Theme.Text}, 0.2) end
    end

    tabBtn.MouseButton1Click:Connect(switchTo)
    tabBtn.MouseEnter:Connect(function()
        if libSelf._activeCategory ~= name then
            tween(tabBtn, {BackgroundTransparency = 0.1}, 0.15)
            if tabText then tween(tabText, {TextColor3 = Theme.Text}, 0.15) end
            local ico = tabBtn:FindFirstChild("Icon")
            if ico then tween(ico, {ImageColor3 = Theme.Text}, 0.15) end
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if libSelf._activeCategory ~= name then
            tween(tabBtn, {BackgroundTransparency = 0.3}, 0.15)
            if tabText then tween(tabText, {TextColor3 = Theme.SubText}, 0.15) end
            local ico = tabBtn:FindFirstChild("Icon")
            if ico then tween(ico, {ImageColor3 = Theme.SubText}, 0.15) end
        end
    end)

    if self._tabOrder == 1 then
        libSelf._activeCategory = nil
        switchTo()
    end

    -- Return Category object
    local cat = setmetatable({}, Category)
    cat._lib = self
    cat._name = name
    cat._page = page
    cat._data = self._categories[name]
    return cat
end

-- ═══════════════════════════════════════════════════
--  CATEGORY: pick the column with the lowest item count
-- ═══════════════════════════════════════════════════
function Category:_getColumn(colNum)
    if colNum then
        return self._data.cols[colNum], colNum
    end
    -- Auto-balance: pick the column with the fewest items
    local minIdx, minVal = 1, self._data.colOrders[1]
    for i = 2, Theme.Columns do
        if self._data.colOrders[i] < minVal then
            minIdx = i
            minVal = self._data.colOrders[i]
        end
    end
    return self._data.cols[minIdx], minIdx
end

function Category:_incOrder(colIdx)
    self._data.colOrders[colIdx] = self._data.colOrders[colIdx] + 1
    return self._data.colOrders[colIdx]
end

